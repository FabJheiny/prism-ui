        Size             = UDim2.fromScale(1,1),
        BackgroundColor3 = Color3.fromRGB(30, 26, 72),
        BackgroundTransparency = .88,
        BorderSizePixel  = 0,
        ZIndex           = pill.ZIndex - 1,
        Parent           = pill,
    })
    Corner(glowBg, 22)

    -- Ícone (lado esquerdo)
    local iconFrame = Create("Frame",{
        Size             = UDim2.fromOffset(32,32),
        Position         = UDim2.fromOffset(6,6),
        BackgroundColor3 = Theme.Glow,
        BackgroundTransparency = .6,
        BorderSizePixel  = 0,
        ZIndex           = pill.ZIndex + 1,
        Parent           = pill,
    })
    Corner(iconFrame, 999)
    Gradient(iconFrame,{
        ColorSequenceKeypoint.new(0, Theme.Accent1),
        ColorSequenceKeypoint.new(1, Theme.Accent2),
    },45)

    local iconLabel = Create("TextLabel",{
        Text               = icon,
        Font               = Enum.Font.GothamBold,
        TextSize           = 15,
        TextColor3         = Color3.new(1,1,1),
        BackgroundTransparency = 1,
        Size               = UDim2.fromScale(1,1),
        ZIndex             = pill.ZIndex + 2,
        Parent             = iconFrame,
    })

    -- Texto (lado direito)
    local textLabel = Create("TextLabel",{
        Text               = label,
        Font               = Enum.Font.GothamBold,
        TextSize           = 11,
        TextColor3         = Color3.fromRGB(210,196,255),
        BackgroundTransparency = 1,
        Position           = UDim2.fromOffset(44, 7),
        Size               = UDim2.new(1,-50,0,14),
        TextXAlignment     = Enum.TextXAlignment.Left,
        TextTruncate       = Enum.TextTruncate.AtEnd,
        ZIndex             = pill.ZIndex + 1,
        Parent             = pill,
    })

    if description ~= "" then
        Create("TextLabel",{
            Text               = description,
            Font               = Enum.Font.Gotham,
            TextSize           = 8,
            TextColor3         = Theme.SubText,
            BackgroundTransparency = 1,
            Position           = UDim2.fromOffset(44, 23),
            Size               = UDim2.new(1,-50,0,12),
            TextXAlignment     = Enum.TextXAlignment.Left,
            TextTruncate       = Enum.TextTruncate.AtEnd,
            ZIndex             = pill.ZIndex + 1,
            Parent             = pill,
        })
    end

    -- Botão invisível cobrindo apenas a área de texto (clique)
    local hitBtn = Create("TextButton",{
        Text               = "",
        AutoButtonColor    = false,
        BackgroundTransparency = 1,
        Position           = UDim2.fromOffset(44, 0),
        Size               = UDim2.new(1, -44, 1, 0),
        ZIndex             = pill.ZIndex + 10,
        ClipsDescendants   = false,
        Parent             = pill,
    })

    -- Clique: ripple + callback
    hitBtn.MouseButton1Click:Connect(function()
        Ripple(hitBtn)
        TweenService:Create(glowBg, TweenInfo.new(.07), {
            BackgroundTransparency = .6
        }):Play()
        task.delay(.07, function()
            TweenService:Create(glowBg, TweenInfo.new(.18), {
                BackgroundTransparency = .88
            }):Play()
        end)
        if callback then task.spawn(callback) end
    end)

    -- Hover: só tamanho, sem mexer em Position
    hitBtn.MouseEnter:Connect(function()
        TweenService:Create(pill, TweenInfo.new(.14, Enum.EasingStyle.Quint), {
            Size = UDim2.fromOffset(118, 46),
        }):Play()
    end)
    hitBtn.MouseLeave:Connect(function()
        TweenService:Create(pill, TweenInfo.new(.14, Enum.EasingStyle.Quint), {
            Size = UDim2.fromOffset(112, 44),
        }):Play()
    end)

-- Drag pelo ícone via botão invisível sobreposto (funciona mesmo após pill ficar visível)
    local draggingPill = false
    local dragStartPos, pillStartPos

    local dragHandle = Create("TextButton", {
        Text               = "",
        AutoButtonColor    = false,
        BackgroundTransparency = 1,
        Size               = UDim2.fromScale(1, 1),
        ZIndex             = pill.ZIndex + 15,
        Parent             = iconFrame,
    })

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            draggingPill = true
            dragStartPos = UserInputService:GetMouseLocation()
            pillStartPos = pill.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not draggingPill then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement
        and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local delta = UserInputService:GetMouseLocation() - dragStartPos
        pill.Position = UDim2.new(
            pillStartPos.X.Scale, pillStartPos.X.Offset + delta.X,
            pillStartPos.Y.Scale, pillStartPos.Y.Offset + delta.Y
        )
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            draggingPill = false
        end
    end)

    -- Funções de show/hide com animação
    local function Show()
        pill.Visible = true
        pill.BackgroundTransparency = 1
        TweenService:Create(pill, TweenInfo.new(.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0,
        }):Play()
    end

    local function Hide()
        TweenService:Create(pill, TweenInfo.new(.18, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
            BackgroundTransparency = 1,
        }):Play()
        task.delay(.2, function()
            if pill and pill.Parent then
                pill.Visible = false
            end
        end)
    end

    return { Frame = pill, Show = Show, Hide = Hide }
end

