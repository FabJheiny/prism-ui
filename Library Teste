        Size             = UDim2.fromOffset(112, 44),
        Position         = startPos,
        BackgroundColor3 = Color3.fromRGB(10,8,28),
        BorderSizePixel  = 0,
        ZIndex           = 50,
        Visible          = false,   -- começa oculto; o toggle controla
        Parent           = root,
    })
    Corner(pill, 22)

    -- Borda animada igual ao estilo Prism
    local pillStroke = Stroke(pill, Theme.Accent1, 1.5, .3)
    AnimateGradient(Gradient(pillStroke,{
        ColorSequenceKeypoint.new(0,   Theme.Accent1),
        ColorSequenceKeypoint.new(.33, Theme.Accent2),
