        end

        -- ── Textbox ───────────────────────────────────────────
        function tabObj:CreateTextbox(d)
            local el = CreateElement(88)
            Create("TextLabel",{
                Text               = d.Name or "Textbox",
                Font               = Enum.Font.GothamMedium,
                TextSize           = 12,
                TextColor3         = Color3.fromRGB(192,180,232),
                BackgroundTransparency = 1,
                Position           = UDim2.fromOffset(14,14),
                Size               = UDim2.new(1,-28,0,16),
                TextXAlignment     = Enum.TextXAlignment.Left,
                Parent             = el,
            })
            local box = Create("TextBox",{
                PlaceholderText    = d.Placeholder or "Enter...",
                Text               = "",
                Font               = Enum.Font.Gotham,
                TextSize           = 12,
                ClearTextOnFocus   = false,
                MultiLine          = true,
                TextWrapped        = true,
                TextColor3         = Color3.fromRGB(122,114,168),
                PlaceholderColor3  = Color3.fromRGB(122,114,168),
                BackgroundColor3   = Color3.fromRGB(10,8,24),
                BackgroundTransparency = .4,
                Position           = UDim2.fromOffset(14,38),
                Size               = UDim2.new(1,-28,0,42),
                BorderSizePixel    = 0,
                TextXAlignment     = Enum.TextXAlignment.Left,
                TextYAlignment     = Enum.TextYAlignment.Top,
                Parent             = el,
            })
            Corner(box, 8)
            Stroke(box, Theme.Glow, 1, .88)
            Create("UIPadding",{
                PaddingTop    = UDim.new(0,10), PaddingBottom = UDim.new(0,10),
                PaddingLeft   = UDim.new(0,12), PaddingRight  = UDim.new(0,12),
                Parent        = box,
            })
            box:GetPropertyChangedSignal("TextBounds"):Connect(function()
                local h = math.max(box.TextBounds.Y + 20, 42)
                box.Size = UDim2.new(1,-28,0,h)
                el.Size  = UDim2.new(1,0,0,h + 46)
            end)
            box.Focused:Connect(function()
                TweenService:Create(box, TweenInfo.new(.15, Enum.EasingStyle.Quint), {
                    BackgroundTransparency = .2
                }):Play()
            end)
            box.FocusLost:Connect(function()
                TweenService:Create(box, TweenInfo.new(.15, Enum.EasingStyle.Quint), {
                    BackgroundTransparency = .4
                }):Play()
            end)
        end

        -- ── Label ─────────────────────────────────────────────
        function tabObj:CreateLabel(text)
            local el = Create("Frame",{
                Size               = UDim2.new(1,0,0,32),
                BackgroundTransparency = 1,
                Parent             = page,
            })
            local line = Create("Frame",{
                Size             = UDim2.new(0,2,1,0),
                BackgroundColor3 = Theme.Accent1,
                BorderSizePixel  = 0,
                Parent           = el,
            })
            Gradient(line,{
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,96,144)),
                ColorSequenceKeypoint.new(1, Theme.Accent2),
            },90)
            Create("TextLabel",{
                Text               = text,
                Font               = Enum.Font.GothamMedium,
                TextSize           = 11,
                TextColor3         = Color3.fromRGB(74,72,112),
                BackgroundTransparency = 1,
                Position           = UDim2.fromOffset(12,0),
                Size               = UDim2.new(1,-12,1,0),
                TextXAlignment     = Enum.TextXAlignment.Left,
                Parent             = el,
            })
        end

        -- ── Paragraph ─────────────────────────────────────────
        function tabObj:CreateParagraph(d)
            local el = CreateElement(72)
            local titleL = Create("TextLabel",{
                Text               = d.Title or "About",
                Font               = Enum.Font.GothamBold,
                TextSize           = 12,
                TextColor3         = Theme.Accent1,
                BackgroundTransparency = 1,
                Position           = UDim2.fromOffset(14,14),
                Size               = UDim2.new(1,-28,0,16),
                TextXAlignment     = Enum.TextXAlignment.Left,
                Parent             = el,
            })
            Gradient(titleL,{
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,96,144)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(160,128,255)),
            })
            local body = Create("TextLabel",{
                Text               = d.Content or "",
                Font               = Enum.Font.Gotham,
                TextSize           = 11,
                TextWrapped        = true,
                AutomaticSize      = Enum.AutomaticSize.Y,
                TextColor3         = Color3.fromRGB(58,56,88),
                BackgroundTransparency = 1,
                Position           = UDim2.fromOffset(14,34),
                Size               = UDim2.new(1,-28,0,0),
                TextXAlignment     = Enum.TextXAlignment.Left,
                TextYAlignment     = Enum.TextYAlignment.Top,
                Parent             = el,
            })
            el.Size = UDim2.new(1,0,0, body.TextBounds.Y + 48)
        end

        return tabObj
    end

    return windowObj
end

return setmetatable({}, Library)
