        -- ── Dropdown ──────────────────────────────────────────
        -- FIX: optList.Visible=false quando fechado; sem espaço fantasma
        function tabObj:CreateDropdown(d)
            local options  = d.Options or {}
            local current  = d.Default or options[1] or "None"
            local open     = false
            local CLOSED_H = 44
            local OPEN_H   = CLOSED_H + (#options * 30) + 4

            local el = Create("Frame",{
                Size               = UDim2.new(1,0,0,CLOSED_H),
                BackgroundColor3   = Color3.new(1,1,1),
                BackgroundTransparency = .975,
                BorderSizePixel    = 0,
                ClipsDescendants   = true,
                Parent             = page,
            })
            Corner(el, 11)
            Stroke(el, Color3.new(1,1,1), 1, .93)

            local tg = Create("Frame",{
                Size             = UDim2.new(1,0,0,1),
                BackgroundTransparency = .6,
                BorderSizePixel  = 0,
                Parent           = el,
            })
            Gradient(tg,{
                ColorSequenceKeypoint.new(0,  Color3.new(1,1,1)),
                ColorSequenceKeypoint.new(.5, Theme.Glow),
                ColorSequenceKeypoint.new(1,  Color3.new(1,1,1)),
            })

            local row = Create("TextButton",{
                Text               = "",
                AutoButtonColor    = false,
                BackgroundTransparency = 1,
                Size               = UDim2.new(1,0,0,CLOSED_H),
                Parent             = el,
            })
            Create("UIPadding",{
                PaddingLeft  = UDim.new(0,14),
                PaddingRight = UDim.new(0,14),
                Parent       = row,
            })
            Create("TextLabel",{
                Text               = d.Name or "Dropdown",
                Font               = Enum.Font.GothamMedium,
                TextSize           = 12,
                TextColor3         = Color3.fromRGB(192,180,232),
                BackgroundTransparency = 1,
                Size               = UDim2.new(1,-90,1,0),
                TextXAlignment     = Enum.TextXAlignment.Left,
                Parent             = row,
            })
            local valL = Create("TextLabel",{
                Text               = current,
                Font               = Enum.Font.GothamMedium,
                TextSize           = 12,
                TextColor3         = Color3.fromRGB(144,128,216),
                BackgroundTransparency = 1,
                Position           = UDim2.new(1,-86,0,0),
                Size               = UDim2.fromOffset(72,CLOSED_H),
                TextXAlignment     = Enum.TextXAlignment.Right,
                Parent             = row,
            })

            -- seta animada (rotaciona 180° ao abrir)
            local arrowL = Create("TextLabel",{
                Text               = "v",
                Font               = Enum.Font.GothamBold,
                TextSize           = 11,
                TextColor3         = Color3.fromRGB(80,76,120),
                BackgroundTransparency = 1,
                AnchorPoint        = Vector2.new(.5,.5),
                Position           = UDim2.new(1,-9, .5, 0),
                Size               = UDim2.fromOffset(14,14),
                Rotation           = 0,
                Parent             = row,
            })

            -- Lista de opções: inicia INVISÍVEL para não ocupar espaço
            local optList = Create("Frame",{
                BackgroundTransparency = 1,
                Position               = UDim2.fromOffset(0,CLOSED_H),
                Size                   = UDim2.new(1,0,0,#options*30),
                Visible                = false,   -- ← correção principal
                Parent                 = el,
            })
            Create("UIListLayout",{ Parent = optList })

            for _,opt in ipairs(options) do
                local o = Create("TextButton",{
                    Text               = opt,
                    Font               = Enum.Font.GothamMedium,
                    TextSize           = 12,
                    AutoButtonColor    = false,
                    BackgroundTransparency = 1,
                    TextColor3         = Theme.Text,
                    Size               = UDim2.new(1,0,0,30),
                    Parent             = optList,
                })
                Create("UIPadding",{ PaddingLeft = UDim.new(0,14), Parent = o })

                o.MouseEnter:Connect(function()
                    o.BackgroundColor3 = Theme.Glow
                    TweenService:Create(o, TweenInfo.new(.1), {
                        BackgroundTransparency = .92 }):Play()
                end)
                o.MouseLeave:Connect(function()
                    TweenService:Create(o, TweenInfo.new(.1), {
                        BackgroundTransparency = 1 }):Play()
                end)

                o.MouseButton1Click:Connect(function()
                    current   = opt
                    valL.Text = opt
                    open      = true
                    row.MouseButton1Click:Fire()  -- fecha
                    if d.Callback then task.spawn(d.Callback, opt) end
                end)
            end

            row.MouseButton1Click:Connect(function()
                open = not open
                -- mostrar/esconder lista antes/depois da animação
                if open then
                    optList.Visible = true
                end
                TweenService:Create(el, Config.Tween, {
                    Size = UDim2.new(1,0,0, open and OPEN_H or CLOSED_H)
                }):Play()
                TweenService:Create(arrowL, Config.Tween, {
                    Rotation = open and 180 or 0
                }):Play()
                if not open then
                    task.delay(Config.Tween.Time, function()
                        optList.Visible = false
                    end)
                end
            end)

            return {
                Set = function(opt) current = opt; valL.Text = opt end,
                Get = function() return current end,
            }
        end

