-- Atualiza FPS e Ping a cada segundo
local frameCount = 0
local elapsed    = 0
RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1
    elapsed    = elapsed + dt
    if elapsed >= 1 then
        local fps  = math.round(frameCount / elapsed)
        local ping = math.round(Players.LocalPlayer:GetNetworkPing() * 1000)
        fpsValueL.Text  = fps .. " fps"

        local pingColor
        if ping < 80 then
            pingColor = Color3.fromRGB(96,255,160)
        elseif ping < 150 then
            pingColor = Color3.fromRGB(255,210,80)
        else
            pingColor = Color3.fromRGB(255,80,100)
        end
        pingValueL.Text      = ping .. " ms"
        pingValueL.TextColor3 = pingColor

        frameCount = 0
        elapsed    = 0
    end
end)

