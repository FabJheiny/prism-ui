                AnchorPoint = Vector2.new(.5,.5),
                Position = UDim2.new((value-min)/(max-min),0,.5,0),
                Size = UDim2.fromOffset(18,18),
                BackgroundColor3 = Theme.Accent1,
                BorderSizePixel = 0,
                Parent = hitbox
            })

            Corner(thumb,999)
            Stroke(thumb,Color3.new(1,1,1),1,.6)

            Gradient(thumb,{
                ColorSequenceKeypoint.new(0,Theme.Accent1),
                ColorSequenceKeypoint.new(1,Theme.Accent2)
            })

            local dragging = false

            local function Set(v)
                value = math.clamp(math.floor(v),min,max)

                local pct = (value-min)/(max-min)

                fill.Size = UDim2.new(pct,0,1,0)
                thumb.Position = UDim2.new(pct,0,.5,0)

                valueBox.Text = tostring(value)

                if data.Callback then
                    task.spawn(data.Callback,value)
                end
            end

            valueBox.FocusLost:Connect(function()
                local num = tonumber(valueBox.Text)

                if num then
                    Set(num)
                else
                    valueBox.Text = tostring(value)
                end
            end)

            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                end
            end)

            track.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local pct = math.clamp((input.Position.X - hitbox.AbsolutePosition.X)/hitbox.AbsoluteSize.X,0,1)

                    local new = min + ((max-min) * pct)

                    Set(new)
                end
            end)
        end

        return Tab
    end

    return Window
end

return setmetatable({},Library)
