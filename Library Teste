        -- ── Slider ────────────────────────────────────────────
        -- FIX: RenderStepped enquanto arrasta + hitzone cobrindo a track toda
        function tabObj:CreateSlider(d)
            local min   = d.Min or 0
            local max   = d.Max or 100
            local value = d.Default or min

            local el = CreateElement(76)

            local top = Create("Frame",{
                BackgroundTransparency = 1,
                Size     = UDim2.new(1,-28,0,20),
                Position = UDim2.fromOffset(14,12),
                Parent   = el,
            })

            Create("TextLabel",{
                Text               = d.Name or "Slider",
                Font               = Enum.Font.GothamMedium,
                TextSize           = 12,
                TextColor3         = Color3.fromRGB(192,180,232),
                BackgroundTransparency = 1,
                Size               = UDim2.new(1,-58,1,0),
                TextXAlignment     = Enum.TextXAlignment.Left,
                Parent             = top,
            })

            local valLabel = Create("TextLabel",{
                Text               = tostring(value),
                Font               = Enum.Font.GothamBold,
                TextSize           = 12,
                BackgroundTransparency = 1,
                Size               = UDim2.fromOffset(50,20),
                Position           = UDim2.new(1,-50,0,0),
                TextXAlignment     = Enum.TextXAlignment.Right,
                TextColor3         = Color3.new(1,1,1),
                Parent             = top,
            })
            Gradient(valLabel,{
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,96,144)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(96,144,255)),
            })

            -- TextBox transparente por cima do label para digitação direta
            local valBox = Create("TextBox",{
                Text               = "",
                PlaceholderText    = "",
                Font               = Enum.Font.GothamBold,
                TextSize           = 12,
                BackgroundTransparency = 1,
                Size               = UDim2.fromOffset(50,20),
                Position           = UDim2.new(1,-50,0,0),
                TextXAlignment     = Enum.TextXAlignment.Right,
                TextColor3         = Color3.fromRGB(255,120,160),
                TextTransparency   = 1,
                ClearTextOnFocus   = true,
                BorderSizePixel    = 0,
                ZIndex             = valLabel.ZIndex + 1,
                Parent             = top,
            })

            valBox.Focused:Connect(function()
                valBox.Text             = tostring(value)
                valBox.TextTransparency = 0
                valLabel.Visible        = false
            end)

            -- Track mais alta para facilitar clique/toque
            local track = Create("Frame",{
                Size             = UDim2.new(1,-28,0,10),
                Position         = UDim2.fromOffset(14,44),
                BackgroundColor3 = Color3.fromRGB(30,26,60),
                BorderSizePixel  = 0,
                Parent           = el,
            })
            Corner(track, 5)

            local fill = Create("Frame",{
                Size             = UDim2.new((value-min)/(max-min),0,1,0),
                BackgroundColor3 = Theme.Accent1,
                BorderSizePixel  = 0,
                Parent           = track,
            })
            Corner(fill, 5)
            Gradient(fill,{
                ColorSequenceKeypoint.new(0, Theme.Accent1),
                ColorSequenceKeypoint.new(1, Theme.Accent2),
            })

            -- Thumb
            local thumb = Create("Frame",{
                AnchorPoint      = Vector2.new(.5,.5),
                Position         = UDim2.new((value-min)/(max-min),0,.5,0),
                Size             = UDim2.fromOffset(22,22),
                BackgroundColor3 = Theme.Accent1,
                BorderSizePixel  = 0,
                ZIndex           = track.ZIndex + 2,
                Parent           = track,
            })
            Corner(thumb, 999)
            Gradient(thumb,{
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,96,144)),
                ColorSequenceKeypoint.new(1, Theme.Accent2),
            })
            -- ponto branco central no thumb
            local thumbDot = Create("Frame",{
                AnchorPoint      = Vector2.new(.5,.5),
                Position         = UDim2.fromScale(.5,.5),
                Size             = UDim2.fromOffset(6,6),
                BackgroundColor3 = Color3.new(1,1,1),
                BackgroundTransparency = .35,
                BorderSizePixel  = 0,
                Parent           = thumb,
            })
            Corner(thumbDot, 999)

            -- Zona de clique invisível cobrindo TODA a largura da track
            -- e altura generosa (40px) para facilitar toque/mouse
            local hitZone = Create("TextButton",{
                Text               = "",
                BackgroundTransparency = 1,
                Size               = UDim2.new(1,0,0,40),
                AnchorPoint        = Vector2.new(0,.5),
                Position           = UDim2.new(0,0,.5,0),
                ZIndex             = thumb.ZIndex + 10,
                AutoButtonColor    = false,
                Parent             = track,
            })

            local dragging   = false
            local renderConn = nil

            local lastValue = value

            local function SyncUI(v)
                local newVal = math.clamp(math.floor(v + .5), min, max)
                local pct    = (newVal - min) / (max - min)
                fill.Size        = UDim2.new(pct, 0, 1, 0)
                thumb.Position   = UDim2.new(pct, 0, .5, 0)
                valLabel.Text    = tostring(newVal)
                -- callback apenas quando o valor muda de fato
                if newVal ~= lastValue then
                    value     = newVal
                    lastValue = newVal
                    if d.Callback then task.spawn(d.Callback, value) end
                end
            end

            local function FromMouse()
                local mx  = UserInputService:GetMouseLocation().X
                local pct = math.clamp(
                    (mx - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                SyncUI(min + (max - min) * pct)
            end

            local function StartDrag()
                if dragging then return end
                dragging = true
                FromMouse()
                -- RenderStepped: resposta imediata a cada frame enquanto arrasta
                renderConn = RunService.RenderStepped:Connect(function()
                    if dragging then FromMouse() end
                end)
            end

            local function StopDrag()
                if not dragging then return end
                dragging = false
                if renderConn then
                    renderConn:Disconnect()
                    renderConn = nil
                end
            end

            hitZone.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    StartDrag()
                end
            end)

            -- Soltar em qualquer lugar da tela para o drag
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    StopDrag()
                end
            end)

            valBox.FocusLost:Connect(function()
                valBox.TextTransparency = 1
                valLabel.Visible        = true
                local n = tonumber(valBox.Text)
                valBox.Text = ""
                if n then SyncUI(n) end
            end)

            return { Set = SyncUI, Get = function() return value end }
        end

        -- ── Button ────────────────────────────────────────────
