                BorderSizePixel = 0,
                Parent = el
            })

            Corner(drop,8)
            Stroke(drop,Theme.Glow,1,.85)

            local list = Create("UIListLayout",{
                Parent = drop
            })

            local open = false

            local function Toggle()
                open = not open
                drop.Visible = open

                local target = open and (58 + (#options*28) + 8) or 58

                TweenService:Create(el,Config.Tween,{
                    Size = UDim2.new(1,0,0,target)
                }):Play()
            end

            for _,opt in ipairs(options) do
                local o = Create("TextButton",{
                    Text = opt,
                    Font = Enum.Font.GothamMedium,
                    TextSize = 12,
                    AutoButtonColor = false,
                    BackgroundTransparency = 1,
                    TextColor3 = Theme.Text,
                    Size = UDim2.new(1,0,0,28),
                    Parent = drop
                })

                o.MouseButton1Click:Connect(function()
                    current = opt
                    val.Text = opt
                    Toggle()

                    if data.Callback then
                        task.spawn(data.Callback,opt)
                    end
                end)
            end

            row.MouseButton1Click:Connect(Toggle)
        end

