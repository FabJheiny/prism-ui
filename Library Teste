                    Size = btn.Size - UDim2.fromOffset(0,2)
                }):Play()

                task.wait(.08)

                TweenService:Create(btn,TweenInfo.new(.12),{
                    Size = btn.Size + UDim2.fromOffset(0,2)
                }):Play()

                if data.Callback then
                    task.spawn(data.Callback)
                end
            end)
        end

