local RobloxUI = {}
RobloxUI.__index = RobloxUI

function RobloxUI.new(title, version)
    local self = setmetatable({}, RobloxUI)

    local Players = game:GetService("Players")
    local UIS = game:GetService("UserInputService")
    local player = Players.LocalPlayer
    local pg = player:WaitForChild("PlayerGui", 10) or player.PlayerGui

    local old = pg:FindFirstChild("RobloxUI_Lib")
    if old then old:Destroy() end
    local oldBtn = pg:FindFirstChild("RobloxUI_FloatBtn")
    if oldBtn then oldBtn:Destroy() end

    self._connections = {}
    self._UIS = UIS

    self.gui = Instance.new("ScreenGui")
    self.gui.Name = "RobloxUI_Lib"
    self.gui.ResetOnSpawn = false
    self.gui.IgnoreGuiInset = true
    self.gui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    self.gui.DisplayOrder = 10
    self.gui.Parent = pg

    self.menuFrame = Instance.new("Frame")
    self.menuFrame.Name = "MenuFrame"
    self.menuFrame.Size = UDim2.new(0, 480, 0, 340)
    self.menuFrame.Position = UDim2.new(.5, -240, .5, -170)
    self.menuFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    self.menuFrame.BackgroundTransparency = 0.35
    self.menuFrame.BorderSizePixel = 0
    self.menuFrame.Active = true
    self.menuFrame.Parent = self.gui

    local menuCorner = Instance.new("UICorner")
    menuCorner.CornerRadius = UDim.new(0, 10)
    menuCorner.Parent = self.menuFrame

    local menuStroke = Instance.new("UIStroke")
    menuStroke.Color = Color3.fromRGB(255, 255, 255)
    menuStroke.Transparency = 0.85
    menuStroke.Thickness = 1
    menuStroke.Parent = self.menuFrame

    -- TOPBAR
    local topBar = Instance.new("Frame")
    topBar.Name = "TopBar"
    topBar.Size = UDim2.new(1, 0, 0, 28)
    topBar.Position = UDim2.new(0, 0, 0, 0)
    topBar.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    topBar.BackgroundTransparency = 0.6
    topBar.BorderSizePixel = 0
    topBar.Parent = self.menuFrame

    local topCorner = Instance.new("UICorner")
    topCorner.CornerRadius = UDim.new(0, 10)
    topCorner.Parent = topBar

    local topSep = Instance.new("Frame")
    topSep.Size = UDim2.new(1, 0, 0, 1)
    topSep.Position = UDim2.new(0, 0, 1, -1)
    topSep.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    topSep.BackgroundTransparency = 0.82
    topSep.BorderSizePixel = 0
    topSep.Parent = topBar

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(0.6, 0, 1, 0)
    titleLabel.Position = UDim2.new(0, 10, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title or "SPECTRA"
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 12
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = topBar

    local versionLabel = Instance.new("TextLabel")
    versionLabel.Size = UDim2.new(0.35, 0, 1, 0)
    versionLabel.Position = UDim2.new(0.63, 0, 0, 0)
    versionLabel.BackgroundTransparency = 1
    versionLabel.Text = version or "v1.0"
    versionLabel.Font = Enum.Font.Gotham
    versionLabel.TextSize = 10
    versionLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    versionLabel.TextXAlignment = Enum.TextXAlignment.Right
    versionLabel.Parent = topBar

    -- Bottom Info Line
local bottomSep = Instance.new("Frame")
bottomSep.Size = UDim2.new(1, -16, 0, 1)
bottomSep.Position = UDim2.new(0, 8, 1, -24)
bottomSep.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
bottomSep.BackgroundTransparency = 0.9
bottomSep.BorderSizePixel = 0
bottomSep.Parent = self.menuFrame

local obsLabel = Instance.new("TextLabel")
obsLabel.Size = UDim2.new(1, -16, 0, 18)
obsLabel.Position = UDim2.new(0, 8, 1, -20)
obsLabel.BackgroundTransparency = 1
obsLabel.Text = "optimized for first person gameplay"
obsLabel.Font = Enum.Font.Gotham
obsLabel.TextSize = 9
obsLabel.TextColor3 = Color3.fromRGB(130, 130, 130)
obsLabel.TextXAlignment = Enum.TextXAlignment.Left
obsLabel.Parent = self.menuFrame

    -- CONTENT (entre topbar e bottombar)
    self.contentFrame = Instance.new("Frame")
    self.contentFrame.Size = UDim2.new(1, 0, 1, -56)
    self.contentFrame.Position = UDim2.new(0, 0, 0, 28)
    self.contentFrame.BackgroundTransparency = 1
    self.contentFrame.Parent = self.menuFrame

    local function makeHeader(x)
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1/3, 0, 0, 18)
        lbl.Position = UDim2.new(x, 0, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = ""
        lbl.Font = Enum.Font.GothamSemibold
        lbl.TextSize = 11
        lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
        lbl.Parent = self.contentFrame
        return lbl
    end

    self.leftTabLabel  = makeHeader(0)
    self.rightTabLabel = makeHeader(1/3)
    self.thirdTabLabel = makeHeader(2/3)

    local function makeContainer(x)
        local c = Instance.new("ScrollingFrame")
        c.Size = UDim2.new(1/3, -10, 1, -24)
        c.Position = UDim2.new(x, 5, 0, 20)
        c.BackgroundTransparency = 1
        c.BorderSizePixel = 0
        c.ScrollBarThickness = 0
        c.AutomaticCanvasSize = Enum.AutomaticSize.Y
        c.CanvasSize = UDim2.new()
        c.Visible = true
        c.Parent = self.contentFrame

        local layout = Instance.new("UIListLayout")
        layout.Padding = UDim.new(0, 4)
        layout.Parent = c

        return c
    end

    self.leftContainer  = makeContainer(0)
    self.rightContainer = makeContainer(1/3)
    self.thirdContainer = makeContainer(2/3)

    local sep1 = Instance.new("Frame")
    sep1.Size = UDim2.new(0, 1, 1, -8)
    sep1.Position = UDim2.new(1/3, 0, 0, 4)
    sep1.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sep1.BackgroundTransparency = 0.8
    sep1.BorderSizePixel = 0
    sep1.Parent = self.contentFrame

    local sep2 = Instance.new("Frame")
    sep2.Size = UDim2.new(0, 1, 1, -8)
    sep2.Position = UDim2.new(2/3, 0, 0, 4)
    sep2.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sep2.BackgroundTransparency = 0.8
    sep2.BorderSizePixel = 0
    sep2.Parent = self.contentFrame

    -- Float button
    self.btnGui = Instance.new("ScreenGui")
    self.btnGui.Name = "RobloxUI_FloatBtn"
    self.btnGui.ResetOnSpawn = false
    self.btnGui.IgnoreGuiInset = true
    self.btnGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    self.btnGui.DisplayOrder = 999
    self.btnGui.Parent = pg

    local toggleBtn = Instance.new("Frame")
    toggleBtn.Name = "ToggleBtn"
    toggleBtn.Size = UDim2.new(0, 44, 0, 44)
    toggleBtn.Position = UDim2.new(0, 16, .5, -22)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    toggleBtn.BackgroundTransparency = 0.35
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Active = true
    toggleBtn.Parent = self.btnGui

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(1, 0)
    btnCorner.Parent = toggleBtn

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Color = Color3.fromRGB(255, 255, 255)
    btnStroke.Transparency = 0.7
    btnStroke.Thickness = 1.5
    btnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    btnStroke.Parent = toggleBtn

    local btnIcon = Instance.new("TextLabel")
    btnIcon.Size = UDim2.new(1, 0, 1, 0)
    btnIcon.BackgroundTransparency = 1
    btnIcon.Text = "="
    btnIcon.TextColor3 = Color3.fromRGB(255, 255, 255)
    btnIcon.Font = Enum.Font.GothamBold
    btnIcon.TextSize = 22
    btnIcon.Parent = toggleBtn

    local btnDetector = Instance.new("TextButton")
    btnDetector.Size = UDim2.new(1, 0, 1, 0)
    btnDetector.BackgroundTransparency = 1
    btnDetector.Text = ""
    btnDetector.Parent = toggleBtn

    do
        local dragging = false
        local dragStart
        local startPos
        local moved = false
        local DRAG_THRESHOLD = 6

        table.insert(self._connections, btnDetector.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch
            or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                moved = false
                dragStart = input.Position
                startPos = toggleBtn.Position
            end
        end))

        table.insert(self._connections, UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end))

        table.insert(self._connections, UIS.InputChanged:Connect(function(input)
            if not dragging then return end
            if input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch then
                local delta = input.Position - dragStart
                if delta.Magnitude > DRAG_THRESHOLD then
                    moved = true
                end
                if moved then
                    toggleBtn.Position = UDim2.new(
                        startPos.X.Scale, startPos.X.Offset + delta.X,
                        startPos.Y.Scale, startPos.Y.Offset + delta.Y
                    )
                end
            end
        end))

        local visible = true
        table.insert(self._connections, btnDetector.MouseButton1Click:Connect(function()
            if moved then moved = false return end
            visible = not visible
            self.menuFrame.Visible = visible
            btnIcon.Text = visible and "=" or ">"
            btnStroke.Transparency = visible and 0.7 or 0.3
        end))
    end

    return self
end

function RobloxUI:Destroy()
    for _, conn in ipairs(self._connections) do conn:Disconnect() end
    self._connections = {}
    if self.gui    then self.gui:Destroy()    end
    if self.btnGui then self.btnGui:Destroy() end
end

function RobloxUI:_getContainer(side)
    if side == "left"  then return self.leftContainer  end
    if side == "right" then return self.rightContainer end
    if side == "third" then return self.thirdContainer end
    return self.leftContainer
end

function RobloxUI:AddToggle(side, text, default, callback)
    local container = self:_getContainer(side)
    local state = default or false

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -4, 0, 26)
    btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    btn.BackgroundTransparency = 0.6
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.Text = ""
    btn.Parent = container

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Transparency = 0.85
    stroke.Thickness = 1

    local dot = Instance.new("Frame", btn)
    dot.Size = UDim2.new(0, 8, 0, 8)
    dot.Position = UDim2.new(0, 8, 0.5, -4)
    dot.BorderSizePixel = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local label = Instance.new("TextLabel", btn)
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 24, 0, 0)
    label.Size = UDim2.new(1, -30, 1, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = text

    local function refresh()
        if state then
            dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            stroke.Transparency = 0.6
        else
            dot.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            label.TextColor3 = Color3.fromRGB(140, 140, 140)
            stroke.Transparency = 0.88
        end
    end
    refresh()

    table.insert(self._connections, btn.MouseButton1Click:Connect(function()
        state = not state
        refresh()
        if callback then task.spawn(callback, state) end
    end))

    return {
        SetState = function(v) state = v refresh() end,
        GetState = function() return state end,
    }
end

function RobloxUI:AddButton(side, text, callback)
    local container = self:_getContainer(side)

    local btn = Instance.new("TextButton", container)
    btn.Size = UDim2.new(1, -4, 0, 26)
    btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    btn.BackgroundTransparency = 0.6
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 11
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Transparency = 0.85
    stroke.Thickness = 1

    table.insert(self._connections, btn.MouseButton1Down:Connect(function()
        btn.BackgroundTransparency = 0.4
        stroke.Transparency = 0.55
    end))
    table.insert(self._connections, btn.MouseButton1Up:Connect(function()
        btn.BackgroundTransparency = 0.6
        stroke.Transparency = 0.85
    end))
    table.insert(self._connections, btn.MouseLeave:Connect(function()
        btn.BackgroundTransparency = 0.6
        stroke.Transparency = 0.85
    end))
    table.insert(self._connections, btn.MouseButton1Click:Connect(function()
        if callback then task.spawn(callback) end
    end))

    return btn
end

function RobloxUI:AddSlider(side, text, min, max, default, callback)
    local container = self:_getContainer(side)
    local UIS = self._UIS
    local value = math.clamp(default or min, min, max)
    local dragging = false

    local holder = Instance.new("Frame", container)
    holder.Size = UDim2.new(1, -4, 0, 46)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", holder)
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 0, 16)
    label.Font = Enum.Font.Gotham
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = Color3.fromRGB(255, 255, 255)

    local track = Instance.new("Frame", holder)
    track.Size = UDim2.new(1, 0, 0, 4)
    track.Position = UDim2.new(0, 0, 0, 28)
    track.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    track.BackgroundTransparency = 0.85
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    fill.BackgroundTransparency = 0.1
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0, 10, 0, 10)
    knob.AnchorPoint = Vector2.new(.5, .5)
    knob.Position = UDim2.new(0, 0, .5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local function redraw()
        local rel = (value - min) / (max - min)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, 0, .5, 0)
        label.Text = text .. ": " .. tostring(math.floor(value))
    end

    local function update(x)
        local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        value = math.floor(min + (max - min) * rel)
        redraw()
        if callback then task.spawn(callback, value) end
    end

    redraw()

    table.insert(self._connections, track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = true update(inp.Position.X)
        end
    end))
    table.insert(self._connections, knob.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end))
    table.insert(self._connections, UIS.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            update(inp.Position.X)
        end
    end))
    table.insert(self._connections, UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end))

    return {
        GetValue = function() return value end,
        SetValue = function(v) value = math.clamp(v, min, max) redraw() end,
    }
end

function RobloxUI:SetTabNames(left, right, third)
    if self.leftTabLabel  then self.leftTabLabel.Text  = left  or "" end
    if self.rightTabLabel then self.rightTabLabel.Text = right or "" end
    if self.thirdTabLabel then self.thirdTabLabel.Text = third or "" end
end

_G.RobloxUI = RobloxUI
return RobloxUI
