-- ============================================================
--  NexLib · Modular Framework v1.0.0
--  Arquitetura: Registry + EventBus + State + Loader + UI
-- ============================================================

local NexLib = (function()

-- ── CONFIG ────────────────────────────────────────────────────
local CONFIG = {
    version    = "1.0.0",
    name       = "NexLib",
    httpTimeout = 10,
}

-- ── SERVICES ──────────────────────────────────────────────────
local HttpService   = game:GetService("HttpService")
local Players       = game:GetService("Players")
local RunService    = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService  = game:GetService("TweenService")

local LocalPlayer   = Players.LocalPlayer
local PlayerGui     = LocalPlayer:WaitForChild("PlayerGui")

-- ── UTILS ─────────────────────────────────────────────────────
local function generateId(name)
    return name:lower():gsub("%s+", "_") .. "_" .. tostring(tick()):sub(-4)
end

local function timestamp()
    local t = os.date("*t")
    return string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
end

-- ── EVENT BUS ─────────────────────────────────────────────────
local EventBus = {}
EventBus._listeners = {}

function EventBus.on(event, callback)
    if not EventBus._listeners[event] then
        EventBus._listeners[event] = {}
    end
    table.insert(EventBus._listeners[event], callback)
end

function EventBus.off(event, callback)
    if not EventBus._listeners[event] then return end
    for i, cb in ipairs(EventBus._listeners[event]) do
        if cb == callback then
            table.remove(EventBus._listeners[event], i)
            break
        end
    end
end

function EventBus.emit(event, data)
    if not EventBus._listeners[event] then return end
    for _, cb in ipairs(EventBus._listeners[event]) do
        task.spawn(cb, data)
    end
end

-- ── LOGGER ────────────────────────────────────────────────────
local Logger = {}

local function log(level, msg)
    local entry = { type = level, msg = msg, time = timestamp() }
    EventBus.emit("log:entry", entry)
    print(string.format("[NexLib][%s][%s] %s", level:upper(), entry.time, msg))
end

function Logger.info(msg)    log("info",    msg) end
function Logger.success(msg) log("success", msg) end
function Logger.warn(msg)    log("warn",    msg) end
function Logger.error(msg)   log("error",   msg) end

-- ── STATE ─────────────────────────────────────────────────────
local State = {}
State._data = {
    modules        = {},   -- id → descriptor
    categories     = {},   -- ordered list
    loadStatuses   = {},   -- id → "idle"|"loading"|"loaded"|"error"
    activeCategory = "All",
    selectedModule = nil,
    searchQuery    = "",
}

function State.get()
    return State._data
end

function State.set(patch)
    for k, v in pairs(patch) do
        State._data[k] = v
    end
    EventBus.emit("state:change", State._data)
end

-- ── REGISTRY ──────────────────────────────────────────────────
local Registry = {}

function Registry.Register(descriptor)
    assert(type(descriptor) == "table",  "descriptor must be a table")
    assert(type(descriptor.Name) == "string" and #descriptor.Name > 0, "Name required")
    assert(type(descriptor.Load) == "function", "Load function required")

    descriptor.Category    = descriptor.Category    or "Utilities"
    descriptor.Icon        = descriptor.Icon        or "📦"
    descriptor.Description = descriptor.Description or ""
    descriptor.id          = generateId(descriptor.Name)

    local state = State.get()

    -- Register module
    state.modules[descriptor.id] = descriptor
    state.loadStatuses[descriptor.id] = "idle"

    -- Register category if new
    local catFound = false
    for _, c in ipairs(state.categories) do
        if c == descriptor.Category then catFound = true break end
    end
    if not catFound then
        table.insert(state.categories, descriptor.Category)
    end

    Logger.info(string.format("Registered: [%s] %s", descriptor.Category, descriptor.Name))
    EventBus.emit("module:registered", descriptor)
    State.set({})  -- trigger re-render

    return descriptor.id
end

function Registry.Unregister(id)
    local state = State.get()
    if not state.modules[id] then
        Logger.warn("Unregister: module not found → " .. tostring(id))
        return false
    end
    local name = state.modules[id].Name
    state.modules[id] = nil
    state.loadStatuses[id] = nil
    if state.selectedModule == id then
        State.set({ selectedModule = nil })
    end
    Logger.info("Unregistered: " .. name)
    EventBus.emit("module:unregistered", { id = id })
    State.set({})
    return true
end

function Registry.getAll()
    return State.get().modules
end

function Registry.get(id)
    return State.get().modules[id]
end

-- ── LOADER ────────────────────────────────────────────────────
local Loader = {}

function Loader.load(id)
    local state   = State.get()
    local module  = state.modules[id]
    if not module then
        Logger.error("Load failed: module not found → " .. tostring(id))
        return
    end

    if state.loadStatuses[id] == "loading" then
        Logger.warn(module.Name .. " is already loading")
        return
    end
    if state.loadStatuses[id] == "loaded" then
        Logger.info(module.Name .. " already loaded")
        return
    end

    Logger.info("Loading: " .. module.Name)
    state.loadStatuses[id] = "loading"
    EventBus.emit("module:statusChange", { id = id, status = "loading" })

    task.spawn(function()
        local ok, err = pcall(module.Load)
        if ok then
            state.loadStatuses[id] = "loaded"
            Logger.success(module.Name .. " loaded successfully")
            EventBus.emit("module:statusChange", { id = id, status = "loaded" })
            EventBus.emit("module:loaded",       { id = id, module = module })
        else
            state.loadStatuses[id] = "error"
            Logger.error(module.Name .. " failed: " .. tostring(err))
            EventBus.emit("module:statusChange", { id = id, status = "error" })
            EventBus.emit("module:error",        { id = id, error = err })
        end
        EventBus.emit("state:change", State.get())
    end)
end

function Loader.unload(id)
    local state = State.get()
    if state.loadStatuses[id] == "loaded" then
        state.loadStatuses[id] = "idle"
        EventBus.emit("module:statusChange", { id = id, status = "idle" })
        EventBus.emit("state:change", State.get())
        Logger.info("Unloaded: " .. (state.modules[id] and state.modules[id].Name or id))
    end
end

function Loader.loadAll()
    local state = State.get()
    for id in pairs(state.modules) do
        Loader.load(id)
    end
end

-- ── UI ────────────────────────────────────────────────────────
local UI = {}

local function newInst(class, props, parent)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        inst[k] = v
    end
    if parent then inst.Parent = parent end
    return inst
end

local function color(hex)
    hex = hex:gsub("#", "")
    return Color3.fromRGB(
        tonumber("0x"..hex:sub(1,2)),
        tonumber("0x"..hex:sub(3,4)),
        tonumber("0x"..hex:sub(5,6))
    )
end

local function tween(inst, goal, t)
    TweenService:Create(inst, TweenInfo.new(t or 0.18, Enum.EasingStyle.Quad), goal):Play()
end

