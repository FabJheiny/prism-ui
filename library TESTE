				local c = Color3.fromHSV(h_v, s_v, v_v)
				CP.Value = c; preview.BackgroundColor3 = c; opts.callback(c)
			end
			local function makeHSVSlider(name, init, cb)
				local row = Instance.new("Frame", picker)
				row.BackgroundTransparency = 1; row.BorderSizePixel = 0; row.Size = UDim2.new(1, 0, 0, 14)
				local rl = lbl(row, name, 9, T.TextSecondary); rl.Size = UDim2.new(0, 10, 1, 0)
				local tr = Instance.new("Frame", row)
				tr.BackgroundColor3 = Color3.fromRGB(10, 10, 14); tr.BorderSizePixel = 0
				tr.AnchorPoint = Vector2.new(0, 0.5); tr.Size = UDim2.new(1, -14, 0, 4)
				tr.Position = UDim2.new(0, 13, 0.5, 0); corner(tr, 2)
				local fl = Instance.new("Frame", tr)
				fl.BackgroundColor3 = T.Accent; fl.BorderSizePixel = 0
				fl.Size = UDim2.new(init, 0, 1, 0); corner(fl, 2)
				local drag2 = false
				local function upd2(x)
					local a = math.clamp((x - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1)
					fl.Size = UDim2.new(a, 0, 1, 0); cb(a); rebuild()
				end
				tr.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1
						or i.UserInputType == Enum.UserInputType.Touch then drag2 = true; upd2(i.Position.X) end
				end)
				local ca = UIS.InputChanged:Connect(function(i)
					if drag2 and i.UserInputType == Enum.UserInputType.MouseMovement then upd2(i.Position.X) end
				end)
				local cb2 = UIS.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1
						or i.UserInputType == Enum.UserInputType.Touch then drag2 = false end
				end)
				table.insert(_hsvConns, ca); table.insert(_hsvConns, cb2)
			end
			makeHSVSlider("H", h_v, function(a) h_v = a end)
			makeHSVSlider("S", s_v, function(a) s_v = a end)
			makeHSVSlider("V", v_v, function(a) v_v = a end)
			CP.frame.AncestryChanged:Connect(function()
				if not CP.frame:IsDescendantOf(game) then
					for _, c in ipairs(_hsvConns) do pcall(c.Disconnect, c) end
				end
			end)
			header.MouseButton1Click:Connect(function()
				CP.Open = not CP.Open; picker.Visible = CP.Open
				CP.frame.Size = UDim2.new(1, 0, 0, CP.Open and 104 or 34)
			end)
			function CP:Set(c) CP.Value = c; preview.BackgroundColor3 = c; h_v, s_v, v_v = Color3.toHSV(c) end
			return CP
		end

