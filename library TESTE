		function Tab:ButtonGrid(opts)
			opts = validate({ buttons = {}, columns = 2 }, opts)
			local cols  = math.clamp(opts.columns, 1, 4)
			local rows  = math.ceil(#opts.buttons / cols)
			local rowH  = 32
			local gap   = 3
			local total = rows * (rowH + gap) - gap + 6
			local f     = Instance.new("Frame", Tab._scroll)
			f.BackgroundTransparency = 1; f.BorderSizePixel = 0; f.Size = UDim2.new(1, 0, 0, total)
			for i, btn in ipairs(opts.buttons) do
				local row = math.ceil(i / cols) - 1
				local col = (i - 1) % cols
				local w   = 1 / cols
				local b   = Instance.new("TextButton", f)
				b.BackgroundColor3       = T.Surface
				b.BackgroundTransparency = 1
				b.BorderSizePixel        = 0
				b.AutoButtonColor        = false
				b.Size                   = UDim2.new(w, -(gap * (cols - 1) / cols), 0, rowH)
				b.Position               = UDim2.new(col * w, col * gap, 0, row * (rowH + gap))
				b.Text                   = (btn.icon and btn.icon ~= "" and btn.icon .. " " or "") .. btn.name
				b.Font                   = Enum.Font.GothamBold
				b.TextSize               = 12
				b.TextColor3             = T.TextPrimary
				corner(b, 4); stroke(b, T.Border)
				if not MOBILE then
					b.MouseEnter:Connect(function() b.BackgroundTransparency = 0; b.TextColor3 = T.Accent end)
					b.MouseLeave:Connect(function() b.BackgroundTransparency = 1; b.TextColor3 = T.TextPrimary end)
				end
				-- Usa tap seguro para mobile
				b.MouseButton1Click:Connect(function() pcall(btn.callback) end)
				do
					local gs, gm = nil, false
					b.InputBegan:Connect(function(i)
						if i.UserInputType == Enum.UserInputType.Touch then
							gs = i.Position; gm = false
							b.BackgroundTransparency = 0.5
						end
					end)
					b.InputChanged:Connect(function(i)
						if i.UserInputType == Enum.UserInputType.Touch and gs then
							local d = i.Position - gs
							if math.abs(d.X) > 8 or math.abs(d.Y) > 8 then
								gm = true
								b.BackgroundTransparency = 1
							end
						end
					end)
					b.InputEnded:Connect(function(i)
						if i.UserInputType == Enum.UserInputType.Touch then
							b.BackgroundTransparency = 1
							if not gm then pcall(btn.callback) end
							gs = nil; gm = false
						end
					end)
				end
			end
			return f
		end

