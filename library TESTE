		function Tab:Paragraph(opts)
			opts = validate({ title = "", text = "", color = nil }, opts)
			local charsPerLine = math.max(1, math.floor(300 / 7))
			local lines        = math.max(1, math.ceil(#opts.text / charsPerLine))
			local bodyH        = lines * 15 + 4
			local titleH       = opts.title ~= "" and 18 or 0
			local totalH       = titleH + bodyH + 14
			local f            = base("Paragraph", totalH)
			pad(f, 7, 8, 7, 10)
			local yOff = 0
			if opts.title ~= "" then
				local tl = lbl(f, opts.title, 13, T.TextPrimary, UBUNTU_BOLD)
				tl.Size = UDim2.new(1, 0, 0, 18); tl.Position = UDim2.new(0, 0, 0, 0)
				yOff = 20
			end
			local bl = lbl(f, opts.text, 12, opts.color or T.TextSecondary)
			bl.TextWrapped  = true
			bl.TextTruncate = Enum.TextTruncate.None
			bl.Size         = UDim2.new(1, 0, 0, bodyH)
			bl.Position     = UDim2.new(0, 0, 0, yOff)
			return f
		end

