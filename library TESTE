}

local function tw(obj, goal, ti, cb)
	local t = TweenService:Create(obj, ti or TI_FAST, goal)
	if cb then t.Completed:Once(cb) end
	t:Play(); return t
end

local function corner(p, r)
	local c = Instance.new("UICorner", p)
	c.CornerRadius = UDim.new(0, r or 5)
	return c
end

local function stroke(p, col, thick)
	local s = Instance.new("UIStroke", p)
	s.Color = col or Library.Theme.Border
	s.Thickness = thick or 1
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	return s
end

local function pad(p, t, r, b, l)
	local u = Instance.new("UIPadding", p)
	u.PaddingTop    = UDim.new(0, t or 0)
	u.PaddingRight  = UDim.new(0, r or 0)
	u.PaddingBottom = UDim.new(0, b or 0)
	u.PaddingLeft   = UDim.new(0, l or 0)
end

local UBUNTU      = Font.new("rbxasset://fonts/families/Ubuntu.json")
local UBUNTU_BOLD = Font.new("rbxasset://fonts/families/Ubuntu.json", Enum.FontWeight.Bold)
local MONO        = Font.new("rbxasset://fonts/families/RobotoMono.json")

local function lbl(p, text, size, color, font, xalign)
	local l = Instance.new("TextLabel", p)
	l.BackgroundTransparency = 1
	l.BorderSizePixel = 0
	l.TextSize = size or 13
	l.TextXAlignment = xalign or Enum.TextXAlignment.Left
	l.FontFace = font or UBUNTU
	l.TextColor3 = color or Library.Theme.TextPrimary
	l.Text = text or ""
	l.TextTruncate = Enum.TextTruncate.AtEnd
	l.Size = UDim2.new(1, 0, 1, 0)
	return l
end

local function validate(defaults, opts)
	opts = opts or {}
	for k, v in pairs(defaults) do
		if opts[k] == nil then opts[k] = v end
	end
	return opts
end

local function stripEmoji(str)
	if not str then return "" end
	return str:gsub("[\xC2-\xFD][\x80-\xBF]*", ""):match("^%s*(.-)%s*$")
end

local function destroyExisting()
	local function clean(c)
		for _, ch in ipairs(c:GetChildren()) do
			if ch:IsA("ScreenGui") and ch.Name == "VenturaUI" then
				pcall(ch.Destroy, ch)
			end
		end
	end
	pcall(clean, CoreGui)
	local pg = LP:FindFirstChild("PlayerGui")
	if pg then pcall(clean, pg) end
end

-- ── Helper: conecta tap/click num TextButton já existente.
--    Desktop → MouseButton1Click.
--    Mobile  → dispara só se o dedo não arrastou (scroll seguro).
--    O botão NÃO é criado aqui; o chamador cria e passa como argumento
--    para poder escolher o tamanho certo (não cobrir área de scroll). ──
local function bindTap(btn, onTap)
	-- Desktop
	btn.MouseButton1Click:Connect(onTap)
	-- Mobile: só dispara ao soltar sem arrastar
	local touchStart, touchMoved = nil, false
	btn.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.Touch then
			touchStart = i.Position
			touchMoved = false
		end
	end)
	btn.InputChanged:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.Touch and touchStart then
			local d = i.Position - touchStart
			if math.abs(d.X) > 8 or math.abs(d.Y) > 8 then
				touchMoved = true
			end
		end
	end)
	btn.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.Touch then
			if not touchMoved then onTap() end
			touchStart = nil
			touchMoved = false
		end
	end)
end

-- Cria TextButton invisível filho de `parent` com tamanho/posição dados e bindTap
local function makeTapButton(parent, zIndex, onTap, size, pos)
	local btn = Instance.new("TextButton", parent)
	btn.BackgroundTransparency = 1
	btn.BorderSizePixel        = 0
	btn.Size                   = size or UDim2.new(1, 0, 1, 0)
	btn.Position               = pos  or UDim2.new(0, 0, 0, 0)
	btn.Text                   = ""
	btn.AutoButtonColor        = false
	btn.ZIndex                 = zIndex or 10
	bindTap(btn, onTap)
	return btn
end

