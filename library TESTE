			clickBtn.MouseButton1Up:Connect(function()
				Btn.frame.BackgroundTransparency = 1
				Btn.frame.BackgroundColor3       = T.Surface
				bStroke.Color                    = T.Border
			end)
			-- Desktop click
			clickBtn.MouseButton1Click:Connect(function()
				opts.callback()
			end)
			-- Mobile: tap seguro (só dispara se não arrastou)
			local tapStart, tapMoved = nil, false
			clickBtn.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.Touch then
					tapStart = i.Position; tapMoved = false
					Btn.frame.BackgroundTransparency = 0.45
					Btn.frame.BackgroundColor3       = Color3.fromRGB(0, 0, 0)
				end
			end)
			clickBtn.InputChanged:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.Touch and tapStart then
					local d = i.Position - tapStart
					if math.abs(d.X) > 8 or math.abs(d.Y) > 8 then
						tapMoved = true
						Btn.frame.BackgroundTransparency = 1
						Btn.frame.BackgroundColor3       = T.Surface
						bStroke.Color                    = T.Border
					end
				end
			end)
			clickBtn.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.Touch then
					Btn.frame.BackgroundTransparency = 1
					Btn.frame.BackgroundColor3       = T.Surface
					bStroke.Color                    = T.Border
					if not tapMoved then opts.callback() end
					tapStart = nil; tapMoved = false
				end
			end)

			return Btn
		end

