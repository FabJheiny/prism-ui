		function Tab:ColorPicker(opts)
			opts = validate({ name = "Color", default = Color3.fromRGB(220, 220, 225), callback = function() end }, opts)
			local CP = { Value = opts.default, Open = false }
			CP.frame = base("ColorPicker", 36)
			CP.frame.ClipsDescendants = true
			pad(CP.frame, 0, 8, 0, 10)
			local header = Instance.new("TextButton", CP.frame)
			header.BackgroundTransparency = 1; header.BorderSizePixel = 0
			header.Size = UDim2.new(1, 0, 0, 36); header.Text = ""; header.AutoButtonColor = false; header.ZIndex = 5
			local nl = lbl(CP.frame, opts.name, 13, T.TextPrimary); nl.Size = UDim2.new(1, -34, 0, 36); nl.ZIndex = 4
			local preview = Instance.new("Frame", CP.frame)
			preview.BackgroundColor3 = opts.default; preview.BorderSizePixel = 0
			preview.AnchorPoint = Vector2.new(1, 0); preview.Size = UDim2.new(0, 22, 0, 16)
			preview.Position = UDim2.new(1, 0, 0, 10); preview.ZIndex = 4
			corner(preview, 3); stroke(preview, T.Border)
			local picker = Instance.new("Frame", CP.frame)
			picker.BackgroundColor3       = Color3.fromRGB(14, 14, 18)
			picker.BackgroundTransparency = 1
			picker.BorderSizePixel        = 0
			picker.Size                   = UDim2.new(1, 0, 0, 76)
			picker.Position               = UDim2.new(0, 0, 0, 30)
			picker.Visible                = false
			corner(picker, 4); pad(picker, 5, 8, 5, 8)
			local pL = Instance.new("UIListLayout", picker)
			pL.Padding   = UDim.new(0, 4)
			pL.SortOrder = Enum.SortOrder.LayoutOrder
			local h_v, s_v, v_v = Color3.toHSV(opts.default)
			local _hsvConns      = {}
			local function rebuild()
				local c = Color3.fromHSV(h_v, s_v, v_v)
				CP.Value = c; preview.BackgroundColor3 = c; opts.callback(c)
			end
			local function makeHSVSlider(name, init, cb)
				local row = Instance.new("Frame", picker)
				row.BackgroundTransparency = 1; row.BorderSizePixel = 0; row.Size = UDim2.new(1, 0, 0, 16)
				local rl = lbl(row, name, 10, T.TextSecondary); rl.Size = UDim2.new(0, 10, 1, 0)
				local tr = Instance.new("Frame", row)
				tr.BackgroundColor3 = Color3.fromRGB(10, 10, 14); tr.BorderSizePixel = 0
				tr.AnchorPoint = Vector2.new(0, 0.5); tr.Size = UDim2.new(1, -14, 0, 4)
				tr.Position = UDim2.new(0, 13, 0.5, 0); corner(tr, 2)
				local fl = Instance.new("Frame", tr)
				fl.BackgroundColor3 = T.Accent; fl.BorderSizePixel = 0
				fl.Size = UDim2.new(init, 0, 1, 0); corner(fl, 2)
				local drag2 = false
				local function upd2(x)
					local a = math.clamp((x - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1)
					fl.Size = UDim2.new(a, 0, 1, 0); cb(a); rebuild()
				end
				-- Inicia drag apenas com InputBegan no track (não por hover)
				tr.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1
						or i.UserInputType == Enum.UserInputType.Touch then drag2 = true; upd2(i.Position.X) end
				end)
				local ca = UIS.InputChanged:Connect(function(i)
					if drag2 and (i.UserInputType == Enum.UserInputType.MouseMovement
						or i.UserInputType == Enum.UserInputType.Touch) then upd2(i.Position.X) end
				end)
				local cb2 = UIS.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1
						or i.UserInputType == Enum.UserInputType.Touch then drag2 = false end
				end)
				table.insert(_hsvConns, ca); table.insert(_hsvConns, cb2)
			end
			makeHSVSlider("H", h_v, function(a) h_v = a end)
			makeHSVSlider("S", s_v, function(a) s_v = a end)
			makeHSVSlider("V", v_v, function(a) v_v = a end)
			CP.frame.AncestryChanged:Connect(function()
				if not CP.frame:IsDescendantOf(game) then
					for _, c in ipairs(_hsvConns) do pcall(c.Disconnect, c) end
				end
			end)
			-- ColorPicker header: tap seguro no mobile
			header.MouseButton1Click:Connect(function()
				CP.Open = not CP.Open; picker.Visible = CP.Open
				CP.frame.Size = UDim2.new(1, 0, 0, CP.Open and 110 or 36)
			end)
			do
				local cs, cm = nil, false
				header.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.Touch then
						cs = i.Position; cm = false
					end
				end)
				header.InputChanged:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.Touch and cs then
						local d = i.Position - cs
						if math.abs(d.X) > 8 or math.abs(d.Y) > 8 then cm = true end
					end
				end)
				header.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.Touch then
						if not cm then
							CP.Open = not CP.Open; picker.Visible = CP.Open
							CP.frame.Size = UDim2.new(1, 0, 0, CP.Open and 110 or 36)
						end
						cs = nil; cm = false
					end
				end)
			end
			function CP:Set(c) CP.Value = c; preview.BackgroundColor3 = c; h_v, s_v, v_v = Color3.toHSV(c) end
			return CP
		end

