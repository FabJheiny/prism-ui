	local floatFadeTask = nil
	local function floatShow()
		if floatFadeTask then task.cancel(floatFadeTask) end
		tw(floatBtn, { BackgroundTransparency = 0.08 }, TI_FAST)
		floatFadeTask = task.delay(3, function()
			tw(floatBtn, { BackgroundTransparency = 0.55 }, TI_MED)
		end)
	end

	local fbDrag, fbStart, fbOrigin, fbMoved = false, nil, nil, false
	floatBtn.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
			or i.UserInputType == Enum.UserInputType.Touch then
			fbDrag  = true; fbMoved = false
			fbStart = i.Position; fbOrigin = floatBtn.Position
		end
	end)
	track(UIS.InputChanged:Connect(function(i)
		if not fbDrag then return end
		if i.UserInputType ~= Enum.UserInputType.MouseMovement
			and i.UserInputType ~= Enum.UserInputType.Touch then return end
		local d = i.Position - fbStart
		if math.abs(d.X) > 5 or math.abs(d.Y) > 5 then
			fbMoved = true
			local vps = workspace.CurrentCamera.ViewportSize
			floatBtn.Position = UDim2.new(0,
				math.clamp(fbOrigin.X.Offset + d.X, FB/2, vps.X - FB/2),
				0,
				math.clamp(fbOrigin.Y.Offset + d.Y, FB/2, vps.Y - FB/2))
		end
	end))
	track(UIS.InputEnded:Connect(function(i)
		if i.UserInputType ~= Enum.UserInputType.MouseButton1
			and i.UserInputType ~= Enum.UserInputType.Touch then return end
		if fbDrag and not fbMoved then
			_open = not _open
			Main.Visible = _open
		end
		if fbDrag then floatShow() end
		fbDrag = false
	end))
	track(UIS.InputBegan:Connect(function(input, gpe)
		if _destroyed or gpe then return end
		if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
		if input.KeyCode == options.toggleKey then
			_open = not _open
			Main.Visible = _open
			floatShow()
		end
	end))


