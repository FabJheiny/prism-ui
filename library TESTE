			if GUI.CurrentTab then GUI.CurrentTab:Deactivate() end
			Tab.Active           = true
			Tab._scroll.Position = UDim2.new(0, 0, 0, 0)
			GUI.CurrentTab       = Tab
			Tab._navBtn.BackgroundTransparency = 0.35
			navText.TextColor3 = T.TextPrimary
			tw(Tab._indicator, { Size = UDim2.new(0, 2, 0.6, 0) })
		end

		function Tab:Deactivate()
			if not Tab.Active then return end
			Tab.Active           = false
			Tab._scroll.Position = UDim2.new(0, 99999, 0, 0)
			Tab._navBtn.BackgroundTransparency = 1
			navText.TextColor3 = T.TextSecondary
			tw(Tab._indicator, { Size = UDim2.new(0, 0, 0.6, 0) })
		end

