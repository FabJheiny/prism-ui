		function Tab:Slider(opts)
			opts = validate({ name = "Slider", min = 0, max = 100, default = 50, callback = function() end }, opts)
			local Slider = { Value = opts.default, Dragging = false }
			Slider.frame = base("Slider", 54)
			pad(Slider.frame, 8, 10, 9, 10)
			local nl = lbl(Slider.frame, opts.name, 13, T.TextPrimary)
			nl.Size = UDim2.new(1, -46, 0, 17)
			local vl = lbl(Slider.frame, tostring(opts.default), 12, T.TextSecondary, nil, Enum.TextXAlignment.Right)
			vl.AnchorPoint = Vector2.new(1, 0)
			vl.Size        = UDim2.new(0, 42, 0, 17)
			vl.Position    = UDim2.new(1, 0, 0, 0)

			local track = Instance.new("Frame", Slider.frame)
			track.BackgroundColor3       = Color3.fromRGB(10, 10, 14)
			track.BackgroundTransparency = 0.3
			track.BorderSizePixel        = 0
			track.AnchorPoint            = Vector2.new(0, 1)
			track.Size                   = UDim2.new(1, 0, 0, 4)
			track.Position               = UDim2.new(0, 0, 1, 0)
			corner(track, 2)

			local fill = Instance.new("Frame", track)
			fill.BackgroundColor3 = T.Accent
			fill.BorderSizePixel  = 0
			fill.Size             = UDim2.new((opts.default - opts.min) / (opts.max - opts.min), 0, 1, 0)
			corner(fill, 2)

			local thumb = Instance.new("Frame", track)
			thumb.BackgroundColor3 = Color3.fromRGB(220, 220, 225)
			thumb.BorderSizePixel  = 0
			thumb.AnchorPoint      = Vector2.new(0.5, 0.5)
			thumb.Size             = UDim2.new(0, 10, 0, 10)
			thumb.Position         = UDim2.new((opts.default - opts.min) / (opts.max - opts.min), 0, 0.5, 0)
			corner(thumb, 5)

			-- hitbox centrado no track, altura generosa para toque fácil,
			-- mas NÃO cobre o frame inteiro (não bloqueia scroll vertical)
			local hitbox = Instance.new("TextButton", track)
			hitbox.BackgroundTransparency = 1
			hitbox.BorderSizePixel        = 0
			hitbox.AnchorPoint            = Vector2.new(0, 0.5)
			hitbox.Size                   = UDim2.new(1, 0, 0, 36)
			hitbox.Position               = UDim2.new(0, 0, 0.5, 0)
			hitbox.Text                   = ""
			hitbox.AutoButtonColor        = false
			hitbox.ZIndex                 = 10

			local lastValue   = opts.default
			local renderConn  = nil

			local function syncUI(x)
				local range = opts.max - opts.min
				if range == 0 then return end
				local a   = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
				local val = math.floor(opts.min + range * a)
				fill.Size      = UDim2.new(a, 0, 1, 0)
				thumb.Position = UDim2.new(a, 0, 0.5, 0)
				vl.Text        = tostring(val)
				if val ~= lastValue then
					lastValue    = val
					Slider.Value = val
					opts.callback(val)
				end
			end

			local function fromMouse()
				syncUI(UIS:GetMouseLocation().X)
			end

			local function startDrag()
				if Slider.Dragging then return end
				Slider.Dragging = true
				fromMouse()
				renderConn = RunService.RenderStepped:Connect(function()
					if Slider.Dragging then fromMouse() end
				end)
			end

			local function stopDrag()
				if not Slider.Dragging then return end
				Slider.Dragging = false
				if renderConn then renderConn:Disconnect(); renderConn = nil end
			end

			hitbox.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
					or i.UserInputType == Enum.UserInputType.Touch then
					startDrag()
				end
			end)

			local c1 = UIS.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
					or i.UserInputType == Enum.UserInputType.Touch then
					stopDrag()
				end
			end)
			-- Touch: rastrear posição durante drag
			local c2 = UIS.InputChanged:Connect(function(i)
				if Slider.Dragging and i.UserInputType == Enum.UserInputType.Touch then
					syncUI(i.Position.X)
				end
			end)

			Slider.frame.AncestryChanged:Connect(function()
				if not Slider.frame:IsDescendantOf(game) then
					stopDrag()
					c1:Disconnect(); c2:Disconnect()
				end
			end)

			function Slider:Set(v, silent)
				v = math.clamp(v, opts.min, opts.max)
				local a = (v - opts.min) / (opts.max - opts.min)
				Slider.Value = v; lastValue = v
				fill.Size      = UDim2.new(a, 0, 1, 0)
				thumb.Position = UDim2.new(a, 0, 0.5, 0)
				vl.Text        = tostring(v)
				if not silent then opts.callback(v) end
			end
			return Slider
		end

		function Tab:Dropdown(opts)
			opts = validate({ name = "Dropdown", items = {}, default = nil, multi = false, callback = function() end }, opts)
			local DD = { Open = false, Selected = opts.default, Multi = {} }
			DD.frame = base("Dropdown", 36)
			DD.frame.ClipsDescendants       = true
			DD.frame.BackgroundTransparency = 1
			DD.frame:FindFirstChildOfClass("UIStroke"):Destroy()
			local header = Instance.new("TextButton", DD.frame)
			header.AutoButtonColor        = false
			header.BackgroundColor3       = T.Surface
			header.BackgroundTransparency = 1
			header.BorderSizePixel        = 0
			header.Size                   = UDim2.new(1, 0, 0, 36)
			header.Text                   = ""
			header.ZIndex                 = 2
			corner(header, 5); stroke(header, T.Border)
			local selLbl = lbl(header, opts.default or opts.name, 13, T.TextPrimary)
			selLbl.Size   = UDim2.new(1, -20, 1, 0)
			selLbl.ZIndex = 3
			pad(selLbl, 0, 0, 0, 10)
			local arrowLbl = lbl(header, "v", 12, T.TextSecondary, MONO, Enum.TextXAlignment.Right)
			arrowLbl.AnchorPoint = Vector2.new(1, 0.5)
			arrowLbl.Size        = UDim2.new(0, 16, 0, 16)
			arrowLbl.Position    = UDim2.new(1, -6, 0.5, 0)
			arrowLbl.ZIndex      = 3
			local optHolder = Instance.new("Frame", DD.frame)
			optHolder.BackgroundTransparency = 1
			optHolder.BorderSizePixel        = 0
			optHolder.Size                   = UDim2.new(1, 0, 0, 0)
			optHolder.Position               = UDim2.new(0, 0, 0, 32)
			optHolder.Visible                = false
			optHolder.ZIndex                 = 4
			local ol = Instance.new("UIListLayout", optHolder)
			ol.Padding   = UDim.new(0, 2)
			ol.SortOrder = Enum.SortOrder.LayoutOrder
			local function refresh()
				for _, c in ipairs(optHolder:GetChildren()) do
					if c:IsA("TextButton") then c:Destroy() end
				end
				local total = 0
				for _, item in ipairs(opts.items) do
					local isSel = (opts.multi and DD.Multi[item]) or (not opts.multi and DD.Selected == item)
					local opt   = Instance.new("TextButton", optHolder)
					opt.AutoButtonColor        = false
					opt.BorderSizePixel        = 0
					opt.BackgroundColor3       = isSel and Color3.fromRGB(40, 40, 50) or Color3.fromRGB(22, 22, 28)
					opt.BackgroundTransparency = 1
					opt.TextSize               = 12
					opt.TextXAlignment         = Enum.TextXAlignment.Left
					opt.FontFace               = UBUNTU
					opt.TextColor3             = isSel and T.TextPrimary or T.TextSecondary
					opt.Size                   = UDim2.new(1, 0, 0, 26)
					opt.Text                   = item
					opt.ZIndex                 = 5
					corner(opt, 3); pad(opt, 0, 0, 0, 8)
					-- Usa makeTapButton para itens do dropdown também
					opt.MouseButton1Click:Connect(function()
						if opts.multi then
							DD.Multi[item] = not DD.Multi[item]
							local s = {}
							for k, v in pairs(DD.Multi) do if v then table.insert(s, k) end end
							selLbl.Text = #s > 0 and table.concat(s, ", ") or opts.name
							opts.callback(s); refresh()
						else
							DD.Selected = item; selLbl.Text = item; opts.callback(item)
							DD.Open = false; optHolder.Visible = false
							arrowLbl.Text = "v"
							DD.frame.Size = UDim2.new(1, 0, 0, 36)
							refresh()
						end
					end)
					-- Mobile tap para opção
					do
						local ts2, tm2 = nil, false
						opt.InputBegan:Connect(function(i)
							if i.UserInputType == Enum.UserInputType.Touch then
								ts2 = i.Position; tm2 = false
							end
						end)
						opt.InputChanged:Connect(function(i)
							if i.UserInputType == Enum.UserInputType.Touch and ts2 then
								local d = i.Position - ts2
								if math.abs(d.X) > 8 or math.abs(d.Y) > 8 then tm2 = true end
							end
						end)
						opt.InputEnded:Connect(function(i)
							if i.UserInputType == Enum.UserInputType.Touch then
								if not tm2 then
									if opts.multi then
										DD.Multi[item] = not DD.Multi[item]
										local s = {}
										for k, v in pairs(DD.Multi) do if v then table.insert(s, k) end end
										selLbl.Text = #s > 0 and table.concat(s, ", ") or opts.name
										opts.callback(s); refresh()
									else
										DD.Selected = item; selLbl.Text = item; opts.callback(item)
										DD.Open = false; optHolder.Visible = false
										arrowLbl.Text = "v"
										DD.frame.Size = UDim2.new(1, 0, 0, 36)
										refresh()
									end
								end
								ts2 = nil; tm2 = false
							end
						end)
					end
					total = total + 26
				end
				optHolder.Size = UDim2.new(1, 0, 0, total)
				DD.frame.Size  = UDim2.new(1, 0, 0, DD.Open and (32 + total + 4) or 36)
			end
			-- Header também usa tap seguro
			header.MouseButton1Click:Connect(function()
				DD.Open = not DD.Open
				optHolder.Visible = DD.Open
				arrowLbl.Text     = DD.Open and "^" or "v"
				if DD.Open then refresh() else DD.frame.Size = UDim2.new(1, 0, 0, 36) end
			end)
			do
				local hs, hm = nil, false
				header.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.Touch then
						hs = i.Position; hm = false
					end
				end)
				header.InputChanged:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.Touch and hs then
						local d = i.Position - hs
						if math.abs(d.X) > 8 or math.abs(d.Y) > 8 then hm = true end
					end
				end)
				header.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.Touch then
						if not hm then
							DD.Open = not DD.Open
							optHolder.Visible = DD.Open
							arrowLbl.Text     = DD.Open and "^" or "v"
							if DD.Open then refresh() else DD.frame.Size = UDim2.new(1, 0, 0, 36) end
						end
						hs = nil; hm = false
					end
				end)
			end
			refresh()
			function DD:Set(v) DD.Selected = v; selLbl.Text = v; refresh() end
			function DD:SetItems(newItems)
				opts.items = newItems; DD.Selected = nil; selLbl.Text = opts.name
				if DD.Open then refresh() end
			end
			return DD
		end

