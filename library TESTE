	function GUI:Destroy()
		if _destroyed then return end
		_destroyed = true
		for _, c in ipairs(_connections) do pcall(c.Disconnect, c) end
		_connections = {}
		tw(Main, { Size = UDim2.new(0, winW, 0, 0) }, TI_FAST, function()
			pcall(SG.Destroy, SG)
		end)
		if GUI._floatBtn then pcall(GUI._floatBtn.Destroy, GUI._floatBtn) end
	end

