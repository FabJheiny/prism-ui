	local _cfgFolder = "VenturaUI"
	local _cfgFile   = _cfgFolder .. "/" .. options.name:gsub("[^%w%-%_]", "_") .. ".json"

	local function c3ToHex(c)
		return string.format("%02X%02X%02X",
			math.floor(c.R * 255 + 0.5), math.floor(c.G * 255 + 0.5), math.floor(c.B * 255 + 0.5))
	end
	local function hexToC3(h)
		h = (h or ""):gsub("#", "")
		if #h < 6 then return T.Accent end
		return Color3.fromRGB(tonumber(h:sub(1,2),16) or 0, tonumber(h:sub(3,4),16) or 0, tonumber(h:sub(5,6),16) or 0)
	end
	local function encCfg(t)
		local lines = {}
		for k, v in pairs(t) do table.insert(lines, k .. "=" .. tostring(v)) end
		table.sort(lines); return table.concat(lines, "\n")
	end
	local function decCfg(s)
		local t = {}
		for line in (s .. "\n"):gmatch("([^\n]*)\n") do
			local k, v = line:match("^([^=]+)=(.*)$")
			if k and v then
				k = k:match("^%s*(.-)%s*$"); v = v:match("^%s*(.-)%s*$")
				if v == "true" then t[k] = true elseif v == "false" then t[k] = false
				elseif tonumber(v) then t[k] = tonumber(v) else t[k] = v end
			end
		end
		return t
	end

	function GUI:SaveConfig()
		pcall(function()
			if not isfolder(_cfgFolder) then makefolder(_cfgFolder) end
			writefile(_cfgFile, encCfg({ accent = c3ToHex(T.Accent), winW = math.floor(winW), winH = math.floor(winH) }))
		end)
	end
	function GUI:LoadConfig()
		local ok, raw = pcall(readfile, _cfgFile)
		if not ok or not raw or raw == "" then return nil end
		local ok2, data = pcall(decCfg, raw)
		return (ok2 and data and next(data)) and data or nil
	end
	function GUI:ApplyConfig(data)
		if not data then return end
		if data.accent then T.Accent = hexToC3(data.accent) end
		if data.winW and data.winH then
			winW = math.clamp(tonumber(data.winW) or winW, MIN_W, MAX_W)
			winH = math.clamp(tonumber(data.winH) or winH, MIN_H, MAX_H)
			Main.Size = UDim2.new(0, winW, 0, winH)
		end
	end

	task.delay(0.3, function()
		local d = GUI:LoadConfig(); if d then GUI:ApplyConfig(d) end
	end)

	return GUI
end

return Library
