							selLbl.Text = #s > 0 and table.concat(s, ", ") or opts.name
							opts.callback(s); refresh()
						else
							DD.Selected = item; selLbl.Text = item; opts.callback(item)
							DD.Open = false; optHolder.Visible = false
							arrowLbl.Text = "▾"
							DD.frame.Size = UDim2.new(1, 0, 0, 34)
							refresh()
						end
					end)
					total = total + 24
				end
				optHolder.Size = UDim2.new(1, 0, 0, total)
				DD.frame.Size  = UDim2.new(1, 0, 0, DD.Open and (30 + total + 4) or 34)
			end
			header.MouseButton1Click:Connect(function()
				DD.Open = not DD.Open
				optHolder.Visible = DD.Open
				arrowLbl.Text     = DD.Open and "▴" or "▾"
				if DD.Open then refresh() else DD.frame.Size = UDim2.new(1, 0, 0, 34) end
			end)
