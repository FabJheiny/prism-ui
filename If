local function makeRow(cmd)
    local ROW_H = 22
    local row = newInst("Frame", {
        Size             = UDim2.new(1, 0, 0, ROW_H),
        BackgroundColor3 = T.rowHover,
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
    })
    corner(2, row)

    -- Nome do comando
    local cmdLabel = newInst("TextLabel", {
        Text           = cmd.n,
        Font           = MONO,
        TextSize       = 11,
        TextColor3     = T.cmd,
        BackgroundTransparency = 1,
        Size           = UDim2.new(0, 0, 1, 0),
        Position       = UDim2.new(0, 0, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        AutomaticSize  = Enum.AutomaticSize.X,
        Parent         = row,
    })

    local nameW = #cmd.n * 7

    -- Argumento [speed] etc
    if cmd.a then
        newInst("TextLabel", {
            Text           = " "..cmd.a,
            Font           = MONO,
            TextSize       = 11,
            TextColor3     = T.textArg,
            BackgroundTransparency = 1,
            Size           = UDim2.new(0, 0, 1, 0),
            Position       = UDim2.new(0, nameW, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Left,
            AutomaticSize  = Enum.AutomaticSize.X,
            Parent         = row,
        })
        nameW = nameW + #(" "..cmd.a) * 6
    end

    -- Separador —
    newInst("TextLabel", {
        Text           = "—",
        Font           = MONO,
        TextSize       = 11,
        TextColor3     = T.sep,
        BackgroundTransparency = 1,
        Size           = UDim2.new(0, 22, 1, 0),
        Position       = UDim2.new(0, nameW + 6, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent         = row,
    })

    -- Descrição
    local descX = nameW + 28
    newInst("TextLabel", {
        Text           = truncate(cmd.d, 44),
        Font           = MONO,
        TextSize       = 11,
        TextColor3     = T.desc,
        BackgroundTransparency = 1,
        Size           = UDim2.new(1, -(descX + 84), 1, 0),
        Position       = UDim2.new(0, descX, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate   = Enum.TextTruncate.AtEnd,
        Parent         = row,
    })

    -- Undo / on-off
    if cmd.u then
        local offText = cmd.u == "—" and "on/off" or ("↩"..cmd.u)
        newInst("TextLabel", {
            Text           = offText,
            Font           = MONO,
            TextSize       = 10,
            TextColor3     = T.green,
            BackgroundTransparency = 1,
            Size           = UDim2.new(0, 80, 1, 0),
            Position       = UDim2.new(1, -80, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent         = row,
        })
    end

    -- Hitbox invisível para hover/click
    local hit = newInst("TextButton", {
        Text             = "",
        BackgroundColor3 = T.rowHover,
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 1, 0),
        ZIndex           = 10,
        Parent           = row,
    })
    corner(2, hit)

    hit.MouseEnter:Connect(function()
        tween(hit,      {BackgroundTransparency=0.88}, 0.1)
        tween(cmdLabel, {TextColor3=Color3.fromRGB(255,255,255)}, 0.1)
    end)
    hit.MouseLeave:Connect(function()
        tween(hit,      {BackgroundTransparency=1}, 0.1)
        tween(cmdLabel, {TextColor3=T.cmd}, 0.1)
    end)
    hit.MouseButton1Click:Connect(function()
        tween(hit, {BackgroundTransparency=0.7}, 0.05)
        task.wait(0.05)
        tween(hit, {BackgroundTransparency=1}, 0.1)
        print("[IY] "..cmd.n)
    end)

    return row
end

