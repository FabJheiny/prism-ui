    local nameW = #cmd.n * 7

    newInst("TextLabel", {
        Text           = cmd.n,
        Font           = FONT,
        TextSize       = 12,
        TextColor3     = T.cmd,
        BackgroundTransparency = 1,
        Size           = UDim2.new(0, nameW, 1, 0),
        Position       = UDim2.new(0, 0, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent         = row,
    })

    if cmd.a then
        newInst("TextLabel", {
