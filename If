local BTN_SIZE = 30
local ReopenBtn = newInst("TextButton", {
    Text             = "IY",
    Font             = FONT_BOLD,                    -- negrito
    TextSize         = 12,
    TextColor3       = Color3.fromRGB(255, 255, 255), -- texto mais branco
    BackgroundColor3 = Color3.fromRGB(22, 22, 22),
    BackgroundTransparency = 0.5,                    -- mais opaco (antes 0.7)
    BorderSizePixel  = 0,
    Size             = UDim2.new(0,BTN_SIZE,0,BTN_SIZE),
    Position         = UDim2.new(0,15,0.5,-BTN_SIZE/2),
    Visible          = false,
    ZIndex           = 20,
    Parent           = ScreenGui,
})
newInst("UICorner", {CornerRadius = UDim.new(0, 15), Parent = ReopenBtn})  -- redondo

do
    local rd, rm, rs, rp
    ReopenBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            rd=true; rm=false; rs=inp.Position; rp=ReopenBtn.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if rd and (inp.UserInputType == Enum.UserInputType.MouseMovement
            or inp.UserInputType == Enum.UserInputType.Touch) then
            local d = inp.Position - rs
            if math.abs(d.X) > 3 or math.abs(d.Y) > 3 then rm = true end
            ReopenBtn.Position = UDim2.new(rp.X.Scale, rp.X.Offset+d.X, rp.Y.Scale, rp.Y.Offset+d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then rd = false end
    end)
    ReopenBtn.MouseButton1Click:Connect(function()
        if rm then return end
        ReopenBtn.Visible = false
        Window.Visible    = true
        Window.Size = UDim2.new(0,WIN_W,0,WIN_H)
        Window.BackgroundTransparency = 0
        TopBar.BackgroundTransparency = 0
        minimized = false
    end)
    ReopenBtn.MouseEnter:Connect(function()
        ReopenBtn.BackgroundTransparency = 0.3  -- mais visível ao hover
    end)
    ReopenBtn.MouseLeave:Connect(function()
        ReopenBtn.BackgroundTransparency = 0.5
    end)
end

