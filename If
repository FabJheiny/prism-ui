        tween(hit, {BackgroundTransparency=0.4}, 0.05)
        task.wait(0.05)
        tween(hit, {BackgroundTransparency=1}, 0.1)
        print("[IY] "..cmd.n)
    end)

    return row
end

local function makeSection(catKey, cmds)
    local catColor = CAT_COLORS[catKey]
    local label    = CAT_LABELS[catKey]

    local sec = newInst("Frame", {
        Size             = UDim2.new(1, 0, 0, 0),
        AutomaticSize    = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
    })
    newInst("UIListLayout", {
        Padding   = UDim.new(0, 0),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent    = sec,
    })

    local sh = newInst("Frame", {
        Size             = UDim2.new(1, 0, 0, 18),
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        LayoutOrder      = 0,
        Parent           = sec,
    })

    newInst("TextLabel", {
        Text           = label,
        Font           = FONT,
        TextSize       = 10,
        TextColor3     = T.textDim,
        BackgroundTransparency = 1,
        Size           = UDim2.new(0, 0, 1, 0),
        Position       = UDim2.new(0, 0, 0, 0),
        AutomaticSize  = Enum.AutomaticSize.X,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent         = sh,
    })

    newInst("TextLabel", {
        Text           = tostring(#cmds),
        Font           = FONT,
        TextSize       = 10,
        TextColor3     = T.textDim,
        BackgroundTransparency = 1,
        Size           = UDim2.new(1, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent         = sh,
    })

    newInst("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = Color3.fromRGB(55, 55, 55),
        BackgroundTransparency = 0,
        BorderSizePixel  = 0,
        LayoutOrder      = 1,
        Parent           = sec,
    })

    for i, cmd in ipairs(cmds) do
        if i > 1 then
            newInst("Frame", {
                Size             = UDim2.new(1, 0, 0, 1),
                BackgroundColor3 = Color3.fromRGB(40, 40, 40),
                BackgroundTransparency = 0,
                BorderSizePixel  = 0,
                LayoutOrder      = (i-1)*2,
                Parent           = sec,
            })
        end
        local row = makeRow(cmd)
        row.LayoutOrder = (i-1)*2 + 1
        row.Parent = sec
    end

    return sec
end

render = function(cat, query)
    for _, ch in ipairs(ScrollFrame:GetChildren()) do
        if ch:IsA("GuiObject") and ch ~= ScrollLayout then
            ch:Destroy()
        end
    end

    local q    = (query or ""):lower()
    local cats = cat == "all" and CATEGORIES or {cat}
    local order = 0
    local total = 0

    for _, catKey in ipairs(cats) do
        local filtered = {}
        for _, cmd in ipairs(COMMANDS) do
            if cmd.c == catKey then
                if q == "" or cmd.n:lower():find(q, 1, true) or cmd.d:lower():find(q, 1, true) then
                    table.insert(filtered, cmd)
                end
            end
        end
        if #filtered > 0 then
            local sec = makeSection(catKey, filtered)
            sec.LayoutOrder = order
            sec.Parent = ScrollFrame
            order = order + 1
            total = total + #filtered
        end
    end

    CntLabel.Text = tostring(total).." cmds"

    if order == 0 then
        newInst("TextLabel", {
            Text           = "Nenhum comando encontrado.",
            Font           = FONT,
            TextSize       = 11,
            TextColor3     = T.textDim,
            BackgroundTransparency = 1,
            Size           = UDim2.new(1, 0, 0, 40),
            TextXAlignment = Enum.TextXAlignment.Center,
            LayoutOrder    = 0,
            Parent         = ScrollFrame,
        })
    end
end

