-- ROW
local function makeRow(cmd)
    local row = newInst("Frame", {
        Size                   = UDim2.new(1,0,0,18),
        BackgroundColor3       = T.rowHover,
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
    })

    local nameW = #cmd.n * 6

    newInst("TextLabel", {
        Text                   = cmd.n,
        Font                   = FONT_BOLD,
        TextSize               = 11,
        TextColor3             = T.cmd,
        BackgroundTransparency = 1,
        Size                   = UDim2.new(0,nameW,1,0),
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = row,
    })

    if cmd.a then
        local argW = #(" "..cmd.a) * 5
        newInst("TextLabel", {
            Text                   = " "..cmd.a,
            Font                   = FONT,
            TextSize               = 11,
            TextColor3             = T.textArg,
            BackgroundTransparency = 1,
            Size                   = UDim2.new(0,argW,1,0),
            Position               = UDim2.new(0,nameW,0,0),
            TextXAlignment         = Enum.TextXAlignment.Left,
            Parent                 = row,
        })
        nameW = nameW + argW
    end

    newInst("TextLabel", {
        Text                   = " / "..cmd.d,
        Font                   = FONT,
        TextSize               = 10,
        TextColor3             = T.desc,
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1,-(nameW+70),1,0),
        Position               = UDim2.new(0,nameW+2,0,0),
        TextXAlignment         = Enum.TextXAlignment.Left,
        TextTruncate           = Enum.TextTruncate.AtEnd,
        Parent                 = row,
    })

    if cmd.u then
        newInst("TextLabel", {
            Text                   = cmd.u == "—" and "on/off" or cmd.u,
            Font                   = FONT,
            TextSize               = 9,
            TextColor3             = T.textDim,
            BackgroundTransparency = 1,
            Size                   = UDim2.new(0,60,1,0),
            Position               = UDim2.new(1,-60,0,0),
            TextXAlignment         = Enum.TextXAlignment.Right,
            Parent                 = row,
        })
    end

    local hit = newInst("TextButton", {
        Text                   = "",
        BackgroundColor3       = T.rowHover,
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        Size                   = UDim2.new(1,0,1,0),
        ZIndex                 = 10,
        Parent                 = row,
    })

    hit.MouseEnter:Connect(function()
        hit.BackgroundTransparency = 0.8
    end)
    hit.MouseLeave:Connect(function()
        hit.BackgroundTransparency = 1
    end)
    hit.MouseButton1Click:Connect(function()
        hit.BackgroundTransparency = 0.5
        task.wait(0.05)
        hit.BackgroundTransparency = 1
        print("[IY] "..cmd.n)
    end)

    return row
end

-- RENDER
local function render(query)
    for _, ch in ipairs(ScrollFrame:GetChildren()) do
        if ch:IsA("GuiObject") and ch ~= ScrollLayout then
            ch:Destroy()
        end
    end

    local q = query or ""
    local filtered = {}
    for _, cmd in ipairs(COMMANDS) do
        if q == ""
            or cmd.n:lower():find(q, 1, true)
            or cmd.d:lower():find(q, 1, true)
        then
            table.insert(filtered, cmd)
        end
    end

    if #filtered == 0 then
        newInst("TextLabel", {
            Text                   = "Nenhum comando encontrado.",
            Font                   = FONT,
            TextSize               = 10,
            TextColor3             = T.textDim,
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1,0,0,30),
            TextXAlignment         = Enum.TextXAlignment.Center,
            LayoutOrder            = 0,
            Parent                 = ScrollFrame,
        })
    else
        for i, cmd in ipairs(filtered) do
            local row = makeRow(cmd)
            row.LayoutOrder = i
            row.Parent = ScrollFrame
        end
    end
end

