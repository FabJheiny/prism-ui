local ALL_TABS   = {"all","servidor","movimento","visual","players","personagem","veiculos"}
local TAB_LABELS = {
    all="Todos", servidor="Servidor", movimento="Movimento",
    visual="Visual", players="Players", personagem="Personagem", veiculos="Veículos"
}
local activeTab = "all"
local tabBtns   = {}

local function styleTab(btn, active)
    if active then
        tween(btn, {
            BackgroundColor3       = Color3.fromRGB(32, 10, 60),
            BackgroundTransparency = 0,
            TextColor3             = T.accentL,
        }, 0.12)
        local s = btn:FindFirstChildOfClass("UIStroke")
        if s then tween(s, {Color=T.accent, Transparency=0}, 0.12) end
    else
        tween(btn, {
            BackgroundColor3       = T.bg,
            BackgroundTransparency = 1,
            TextColor3             = T.textDim,
        }, 0.12)
        local s = btn:FindFirstChildOfClass("UIStroke")
        if s then tween(s, {Color=Color3.fromRGB(255,255,255), Transparency=0.92}, 0.12) end
    end
end

local render  -- forward ref

for _, cat in ipairs(ALL_TABS) do
    local isActive = cat == "all"
    local btn = newInst("TextButton", {
        Text                   = TAB_LABELS[cat],
        Font                   = MONO,
        TextSize               = 10,
        TextColor3             = isActive and T.accentL or T.textDim,
        BackgroundColor3       = isActive and Color3.fromRGB(32, 10, 60) or T.bg,
        BackgroundTransparency = isActive and 0 or 1,
        BorderSizePixel        = 0,
        Size                   = UDim2.new(0, 0, 0, 22),
        AutomaticSize          = Enum.AutomaticSize.X,
        Parent                 = TabRow,
    })
    corner(4, btn)
    stroke(
        isActive and T.accent or Color3.fromRGB(255,255,255),
        1,
        isActive and 0 or 0.92,
        btn
    )
    pad(0, 0, 8, 8, btn)
    tabBtns[cat] = btn

    btn.MouseEnter:Connect(function()
        if activeTab ~= cat then tween(btn, {TextColor3=T.text}, 0.1) end
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= cat then tween(btn, {TextColor3=T.textDim}, 0.1) end
    end)
    btn.MouseButton1Click:Connect(function()
        activeTab = cat
        for c, b in pairs(tabBtns) do styleTab(b, c == cat) end
        render(cat, SearchBox.Text:lower())
    end)
end

