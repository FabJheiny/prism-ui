            Position       = UDim2.new(0, nameW, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent         = row,
        })
        nameW = nameW + #(" "..cmd.a) * 6
    end

    newInst("TextLabel", {
        Text           = " / "..cmd.d,
        Font           = FONT,
        TextSize       = 11,
        TextColor3     = T.desc,
        BackgroundTransparency = 1,
        Size           = UDim2.new(1, -(nameW + 80), 1, 0),
        Position       = UDim2.new(0, nameW + 2, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate   = Enum.TextTruncate.AtEnd,
        Parent         = row,
    })

    if cmd.u then
        local offText = cmd.u == "—" and "on/off" or cmd.u
        newInst("TextLabel", {
            Text           = offText,
            Font           = FONT,
            TextSize       = 10,
            TextColor3     = T.textDim,
            BackgroundTransparency = 1,
            Size           = UDim2.new(0, 76, 1, 0),
            Position       = UDim2.new(1, -76, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent         = row,
        })
    end

    local hit = newInst("TextButton", {
        Text             = "",
        BackgroundColor3 = T.rowHover,
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 1, 0),
        ZIndex           = 10,
        Parent           = row,
    })
    corner(2, hit)

    hit.MouseEnter:Connect(function()
        tween(hit, {BackgroundTransparency=0.7}, 0.1)
    end)
    hit.MouseLeave:Connect(function()
        tween(hit, {BackgroundTransparency=1}, 0.1)
    end)
