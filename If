    end)
    ReopenBtn.MouseEnter:Connect(function()
        tween(ReopenBtn, {BackgroundColor3=Color3.fromRGB(40,40,40)}, 0.12)
    end)
    ReopenBtn.MouseLeave:Connect(function()
        tween(ReopenBtn, {BackgroundColor3=Color3.fromRGB(26,26,26)}, 0.12)
    end)
end

CloseBtn.MouseButton1Click:Connect(function()
    tween(Window, {Size=UDim2.new(0,WIN_W,0,0), BackgroundTransparency=1}, 0.18)
    task.wait(0.2)
    Window.Visible    = false
    ReopenBtn.Visible = true
end)
CloseBtn.MouseEnter:Connect(function()
    tween(CloseBtn, {BackgroundTransparency=0.1, TextColor3=Color3.fromRGB(255,255,255)}, 0.1)
end)
CloseBtn.MouseLeave:Connect(function()
    tween(CloseBtn, {BackgroundTransparency=0.6, TextColor3=T.textDim}, 0.1)
end)

local minimized = false
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    tween(Window, {Size=UDim2.new(0, WIN_W, 0, minimized and 38 or WIN_H)}, 0.2)
end)
MinBtn.MouseEnter:Connect(function()
    tween(MinBtn, {BackgroundTransparency=0.1, TextColor3=Color3.fromRGB(255,255,255)}, 0.1)
end)
MinBtn.MouseLeave:Connect(function()
    tween(MinBtn, {BackgroundTransparency=0.6, TextColor3=T.textDim}, 0.1)
end)

do
    local dr, ds, dp
    TopBar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dr=true; ds=inp.Position; dp=Window.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dr and (inp.UserInputType == Enum.UserInputType.MouseMovement
            or inp.UserInputType == Enum.UserInputType.Touch) then
            local d = inp.Position - ds
            Window.Position = UDim2.new(dp.X.Scale, dp.X.Offset+d.X, dp.Y.Scale, dp.Y.Offset+d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then dr = false end
    end)
end

render("all", "")

Window.Size = UDim2.new(0, WIN_W, 0, 0)
Window.BackgroundTransparency = 1
tween(Window, {
    Size = UDim2.new(0, WIN_W, 0, WIN_H),
    BackgroundTransparency = 0,
}, 0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

print("[InfiniteYield GUI] Carregado!")
