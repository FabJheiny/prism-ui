local current = "0"

local function atualizar(valor)
    display.Text = valor
end

local function adicionar(valor)
    if current == "0" then
        current = valor
    else
        current = current .. valor
    end
    atualizar(current)
end

local function calcular()
    local expr = current
    
    -- Processa porcentagens: 100+10% vira 100+(100*10/100) = 110
    expr = expr:gsub("(%d+%.?%d*)([%+%-])(%d+%.?%d*)%%", function(base, op, percent)
        local baseNum = tonumber(base)
        local percentNum = tonumber(percent)
        local percentValue = baseNum * percentNum / 100
        if op == "+" then
            return tostring(baseNum + percentValue)
        elseif op == "-" then
            return tostring(baseNum - percentValue)
        end
    end)
    
    -- Processa multiplicação/divisão com porcentagem: 10%*100 ou 10%100
    expr = expr:gsub("(%d+%.?%d*)%%([%*%/]?)(%d+%.?%d*)", function(percent, op, num)
        local percentNum = tonumber(percent)
        local numValue = tonumber(num)
        local percentValue = numValue * percentNum / 100
        if op == "*" or op == "" then
            return tostring(percentValue)
        elseif op == "/" then
            return tostring(percentNum / 100 / numValue)
        end
    end)
    
    -- Processa multiplicação/divisão com porcentagem invertida: 100*10%
    expr = expr:gsub("(%d+%.?%d*)([%*/])(%d+%.?%d*)%%", function(num, op, percent)
        local numValue = tonumber(num)
        local percentNum = tonumber(percent)
        local percentValue = numValue * percentNum / 100
        if op == "*" then
            return tostring(percentValue)
        elseif op == "/" then
            return tostring(numValue / (percentNum / 100))
        end
    end)
    
    -- Processa porcentagens simples: 10% vira 0.1
    expr = expr:gsub("(%d+%.?%d*)%%", function(num)
        return tostring(tonumber(num) / 100)
    end)
    
    expr = expr:gsub("×", "*"):gsub("÷", "/"):gsub(",", ".")
    
    local success, result = pcall(function()
        return loadstring("return " .. expr)()
    end)
    current = success and tostring(result) or "Erro"
    atualizar(current)
end

local function deletarUltimo()
    if #current <= 1 or current == "Erro" then
        current = "0"
    else
        current = current:sub(1, -2)
    end
    atualizar(current)
end

local BTN    = 36
local STEP   = 38
local STARTX = 6
local STARTY  = 4

local function createButton(texto, x, y, isOperator, isEqual, isDanger, wide)
    local btn = Instance.new("TextButton", btnContainer)
    local w = wide and (BTN * 2 + (STEP - BTN)) or BTN
    btn.Size = UDim2.new(0, w, 0, BTN)
    btn.Position = UDim2.new(0, STARTX + (x * STEP), 0, STARTY + (y * STEP))
    btn.Text = texto
    btn.Font = Enum.Font.SourceSansBold
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.ZIndex = 2

    -- Botão "=" fica redondo, outros ficam quadrados
    if isEqual then
        local btnCorner = Instance.new("UICorner", btn)
        btnCorner.CornerRadius = UDim.new(0, 8)
        btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextColor3 = Color3.fromRGB(0, 0, 0)
        btn.TextSize = 15
    elseif isDanger then
        btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        btn.TextColor3 = Color3.fromRGB(255, 80, 80)
        btn.TextSize = 10
    elseif isOperator then
        btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 15
    else
        btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 11
    end

    btn.MouseButton1Click:Connect(function()
        if texto == "AC" then
            current = "0"
            atualizar(current)
        elseif texto == "DEL" then
            deletarUltimo()
        elseif texto == "=" then
            calcular()
        elseif texto == "%" then
            local ultimo = current:sub(-1)
            if current ~= "0" and current ~= "Erro" then
                current = current .. "%"
                atualizar(current)
            end
        elseif texto == "+" or texto == "-" or texto == "×" or texto == "÷" then
            local ultimo = current:sub(-1)
            if ultimo ~= "+" and ultimo ~= "-" and ultimo ~= "×" and ultimo ~= "÷" and ultimo ~= "%" then
                current = current .. texto
                atualizar(current)
            end
        elseif texto == "." then
            local ultimoNumero = current:match("[%d,]+$") or ""
            if not ultimoNumero:find("%.") then
                current = current .. "."
                atualizar(current)
            end
        elseif texto == "," then
            local ultimoNumero = current:match("[%d%.]+$") or ""
            if not ultimoNumero:find(",") then
                current = current .. ","
                atualizar(current)
            end
        else
            adicionar(texto)
        end
    end)
end

local layout = {
    {"AC",  "DEL",  "%",   "÷"},
    {"7",   "8",    "9",   "×"},
    {"4",   "5",    "6",   "-"},
    {"1",   "2",    "3",   "+"},
}

for y, linha in ipairs(layout) do
    for x, texto in ipairs(linha) do
        local isOperator = (texto == "+" or texto == "-" or texto == "×" or texto == "÷" or texto == "%")
        local isDanger   = (texto == "AC" or texto == "DEL")
        createButton(texto, x-1, y-1, isOperator, false, isDanger, false)
    end
end

createButton("0",  0, 4, false, false, false, false)
createButton(".",  1, 4, false, false, false, false)
createButton(",",  2, 4, false, false, false, false)
