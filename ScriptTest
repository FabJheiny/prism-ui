local espData = {}

local function destroyESP(player)
    local data = espData[player]
    if not data then return end
    if data.NameLabel then
        local bg = data.NameLabel:FindFirstAncestorOfClass("BillboardGui")
        if bg then bg:Destroy() end
    end
    if data.Highlight then data.Highlight:Destroy() end
    espData[player] = nil
end

local function createESP(player, character)
    if player == LocalPlayer then return end
    destroyESP(player)
    local head = character:WaitForChild("Head", 5)
    if not head then return end

    local billboard = Instance.new("BillboardGui", head)
    billboard.Size = UDim2.new(0, 120, 0, 32)
    billboard.StudsOffset = Vector3.new(0, 5, 0)
    billboard.AlwaysOnTop = true

    local nameLabel = Instance.new("TextLabel", billboard)
    nameLabel.Size = UDim2.new(1, 0, 0, 12)
    nameLabel.Position = UDim2.new(0, 0, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextSize = 10
    nameLabel.TextColor3 = Color3.new(1,1,1)
    nameLabel.TextStrokeTransparency = 0

    local distanceLabel = Instance.new("TextLabel", billboard)
    distanceLabel.Size = UDim2.new(1, 0, 0, 12)
    distanceLabel.Position = UDim2.new(0, 0, 0, 14)
    distanceLabel.BackgroundTransparency = 1
    distanceLabel.Font = Enum.Font.Gotham
    distanceLabel.TextSize = 10
    distanceLabel.TextColor3 = Color3.new(1,1,1)
    distanceLabel.TextStrokeTransparency = 0

    local existingHighlight = character:FindFirstChild("ESP_Highlight")
    if existingHighlight then existingHighlight:Destroy() end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillTransparency = 0.6
    highlight.OutlineTransparency = 0
    highlight.Enabled = false
    highlight.Adornee = character
    highlight.Parent = character

    espData[player] = {
        NameLabel = nameLabel,
        DistanceLabel = distanceLabel,
        Character = character,
        Highlight = highlight,
        LastName = "",
        LastDistance = -1
    }
end

local function setupPlayer(player)
    player.CharacterAdded:Connect(function(char)
        task.wait(0.4)
        createESP(player, char)
        if player == LocalPlayer then
            local hum = char:WaitForChild("Humanoid", 5)
            if hum then
                hum.WalkSpeed = playerSpeed
                if noClip then
                    applyNoClip(char)
                end
            end
        end
    end)
    player.CharacterRemoving:Connect(function()
        destroyESP(player)
        if player == LocalPlayer then
            if noClipConnection then
                noClipConnection:Disconnect()
                noClipConnection = nil
            end
        end
    end)
    if player.Character then
        createESP(player, player.Character)
    end
end

for _, p in ipairs(Players:GetPlayers()) do setupPlayer(p) end
Players.PlayerAdded:Connect(setupPlayer)

-- =============================================
-- ESP LOOP
-- =============================================
local updateDelay = 0.25
local lastUpdate = 0

RunService.Heartbeat:Connect(function(dt)
    lastUpdate = lastUpdate + dt
    if lastUpdate < updateDelay then return end
    lastUpdate = 0

    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    for player, data in pairs(espData) do
        local char = data.Character
        if not char or not char.Parent then continue end

        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then
            data.NameLabel.Visible = false
            data.DistanceLabel.Visible = false
            if data.Highlight then data.Highlight.Enabled = false end
            continue
        end

        if not Settings.ESP then
            data.NameLabel.Visible = false
            data.DistanceLabel.Visible = false
            if data.Highlight then data.Highlight.Enabled = false end
            continue
        end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local _, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if not onScreen then
            data.NameLabel.Visible = false
            data.DistanceLabel.Visible = false
            if data.Highlight then data.Highlight.Enabled = false end
            continue
        end

        local dist = (myHRP.Position - hrp.Position).Magnitude
        if dist > 2500 then
            data.NameLabel.Visible = false
            data.DistanceLabel.Visible = false
            if data.Highlight then data.Highlight.Enabled = false end
            continue
        end

        local visible = isPlayerVisible(hrp, char, player)
        local visConfig = visible and ESP_VISIBILITY.VISIBLE or ESP_VISIBILITY.HIDDEN
        local col = visConfig.Color

        if Settings.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team then
            col = Color3.fromRGB(0, 255, 0)
        end

        if data.Highlight then
            if Settings.Highlight then
                data.Highlight.Enabled = true
                data.Highlight.FillColor = col
                data.Highlight.OutlineColor = col
                data.Highlight.FillTransparency = visConfig.FillTransparency
                data.Highlight.OutlineTransparency = visConfig.OutlineTransparency
            else
                data.Highlight.Enabled = false
            end
        end

        data.NameLabel.Visible = Settings.Name
        if Settings.Name then
            if data.LastName ~= player.Name then
                data.NameLabel.Text = player.Name
                data.LastName = player.Name
            end
            data.NameLabel.TextColor3 = col
        end

        data.DistanceLabel.Visible = Settings.Distance
        if Settings.Distance then
            local d = math.floor(dist)
            if data.LastDistance ~= d then
                data.DistanceLabel.Text = visible and ("< " .. d .. "m >") or ("[WALL] " .. d .. "m")
                data.LastDistance = d
            end
            data.DistanceLabel.TextColor3 = col
        end
    end
end)

