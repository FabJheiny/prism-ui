-- NoClip
local noClip = false
local noClipConnection = nil
local originalCollision = {}

local function saveCollision(char)
    originalCollision = {}
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            originalCollision[part] = part.CanCollide
        end
    end
end

local function restoreCollision()
    for part, state in pairs(originalCollision) do
        if part and part.Parent then
            part.CanCollide = state
        end
    end
    originalCollision = {}
end

local function applyNoClip(char)
    if noClipConnection then
        noClipConnection:Disconnect()
        noClipConnection = nil
    end
    if not noClip or not char then return end
    saveCollision(char)
    local lastNoClip = 0
    noClipConnection = RunService.Stepped:Connect(function()
        if not noClip then
            noClipConnection:Disconnect()
            noClipConnection = nil
            return
        end
        if tick() - lastNoClip < 0.1 then return end
        lastNoClip = tick()
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end)
end

ui:AddToggle("third", "NoClip", false, function(state)
    noClip = state
    if state then
        applyNoClip(LocalPlayer.Character)
    else
        if noClipConnection then
            noClipConnection:Disconnect()
            noClipConnection = nil
        end
        restoreCollision()
    end
end)

