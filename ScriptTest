-- AIMBOT
-- =============================================
local function getClosestTarget()
    local closestPart = nil
    local closestWorldDist = math.huge
    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end

        local part = char:FindFirstChild("Head")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not part or not hrp then continue end

        if AimbotSettings.IgnoreAllies and LocalPlayer.Team and player.Team == LocalPlayer.Team then
            continue
        end

        if AimbotSettings.KillCheck then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then continue end
        end

        local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end

        local screenDist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
        if screenDist > AimbotSettings.FOV then continue end

        local worldDist = (myHRP.Position - hrp.Position).Magnitude
        if worldDist > 2000 then continue end

        -- Wall check por partes do corpo
        if not AimbotSettings.IgnoreWall then
            local origin = Camera.CFrame.Position
            local params = RaycastParams.new()
            params.FilterType = Enum.RaycastFilterType.Blacklist
            params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
            params.IgnoreWater = true

            local anyVisible = false
            for _, partName in ipairs(BODY_PARTS_TO_CHECK) do
                local bodyPart = char:FindFirstChild(partName)
                if not bodyPart then continue end
                local ray = workspace:Raycast(origin, bodyPart.Position - origin, params)
                if (not ray) or char:IsAncestorOf(ray.Instance) then
                    anyVisible = true
                    break
                end
            end
            if not anyVisible then continue end
        end

        if worldDist < closestWorldDist then
            closestWorldDist = worldDist
            closestPart = part
        end
    end

    return closestPart
end  -- <-- end que estava faltando

-- =============================================
-- AIMBOT LOOP
-- =============================================
local cachedTarget = nil
RunService.Heartbeat:Connect(function()
    if not AimbotSettings.Enabled then
        cachedTarget = nil
        return
    end
    cachedTarget = getClosestTarget()
end)

local BASE_SMOOTHNESS = 0.9
local currentSmoothness = BASE_SMOOTHNESS
local lastCameraCF = Camera.CFrame
local pullResistance = 0.15
local releaseThreshold = 0.25
local minSmoothness = 0
local lastReleaseTime = 0

RunService.RenderStepped:Connect(function()
    if not cachedTarget then
        lastCameraCF = Camera.CFrame
        currentSmoothness = BASE_SMOOTHNESS
        return
    end

    local lookDelta = (Camera.CFrame.LookVector - lastCameraCF.LookVector).Magnitude

    if lookDelta > releaseThreshold then
        cachedTarget = nil
        currentSmoothness = 0
        lastCameraCF = Camera.CFrame
        lastReleaseTime = tick()
        return
    end

    if lookDelta > pullResistance then
        currentSmoothness = math.max(minSmoothness, currentSmoothness - (lookDelta * 3.5))
    else
        currentSmoothness = currentSmoothness + (BASE_SMOOTHNESS - currentSmoothness) * 0.05
    end

    local targetCF = CFrame.new(Camera.CFrame.Position, cachedTarget.Position)
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, currentSmoothness)
    lastCameraCF = Camera.CFrame
end)

