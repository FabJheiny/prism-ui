-- =============================================
-- ESP VISIBILITY (raycast)
-- =============================================
local ESP_VISIBILITY = {
    ENABLED = true,
    UPDATE_DELAY = 0.4,
    VISIBLE = {
        Color = Color3.fromRGB(255, 0, 0),
        FillTransparency = 0.35,
        OutlineTransparency = 0
    },
    HIDDEN = {
        Color = Color3.fromRGB(160, 0, 0),
        FillTransparency = 0.6,
        OutlineTransparency = 0.3
    }
}

local visibilityCache = {}

local BODY_PARTS_TO_CHECK = {
    "Head", "HumanoidRootPart", "UpperTorso",
    "LeftUpperArm", "RightUpperArm",
    "LeftUpperLeg", "RightUpperLeg"
}

local function isPlayerVisible(part, character, player)
    if not ESP_VISIBILITY.ENABLED then return true end
    local cache = visibilityCache[player]
    if cache and tick() - cache.t < ESP_VISIBILITY.UPDATE_DELAY then
        return cache.v
    end

    local origin = Camera.CFrame.Position
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    params.IgnoreWater = true

    local visible = false
    for _, partName in ipairs(BODY_PARTS_TO_CHECK) do
        local bodyPart = character:FindFirstChild(partName)
        if not bodyPart then continue end
        local ray = workspace:Raycast(origin, bodyPart.Position - origin, params)
        if (not ray) or character:IsAncestorOf(ray.Instance) then
            visible = true
            break
        end
    end

    visibilityCache[player] = {v = visible, t = tick()}
    return visible
end

