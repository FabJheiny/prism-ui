    line2.Size = UDim2.new(0, 1, 1, -26)
    line2.Position = UDim2.new(2/3, 0, 0, 22)
    line2.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    line2.BorderSizePixel = 0
