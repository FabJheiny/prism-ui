    -- === CONTAINERS ===
    local function makeContainer(xScale, xOffset)
        local c = Instance.new("ScrollingFrame")
        c.Size = UDim2.new(1/3, -10, 1, -30)
        c.Position = UDim2.new(xScale, xOffset, 0, 26)
        c.BackgroundTransparency = 1
        c.BorderSizePixel = 0
        c.ScrollBarThickness = 0
        c.CanvasSize = UDim2.new(0, 0, 0, 0)
        c.AutomaticCanvasSize = Enum.AutomaticSize.Y
        c.Parent = self.contentFrame
        local layout = Instance.new("UIListLayout", c)
        layout.Padding = UDim.new(0, 4)
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        return c
    end

    self.leftContainer  = makeContainer(0,     5)
    self.rightContainer = makeContainer(1/3,   5)
    self.thirdContainer = makeContainer(2/3,   5)

