local Services = {
    Players = game:GetService("Players"),
    RunService = game:GetService("RunService"),
    UserInputService = game:GetService("UserInputService"),
    CoreGui = game:GetService("CoreGui")
}

local Config = {
    Float = {
        DefaultSpeed = 0.1,
        MinSpeed = 0.1,
        MaxSpeed = 10,
        PlatformSize = Vector3.new(2, 0.5, 2),
        PlatformOffset = 3.2,
        PlatformTransparency = 0.4
    },
    UI = {
        Name = "FloatV6_Original",
        DisplayOrder = 2147483647,
        Size = UDim2.new(0, 160, 0, 77),
        DefaultPosition = UDim2.new(0.05, 0, 0.4, 0),
        TextSize = 10,
        Font = Enum.Font.GothamSemibold,
        BackgroundColor = Color3.fromRGB(15, 15, 15),
        TextColor = Color3.fromRGB(255, 255, 255),
        DividerColor = Color3.fromRGB(50, 50, 50),
        BorderColor = Color3.fromRGB(255, 255, 255),
        ButtonActive = Color3.fromRGB(0, 170, 255),
        FloatActive = Color3.fromRGB(255, 255, 255)
    }
}

local State = {
    FloatEnabled = false,
    Direction = 0,
    FloatSpeed = Config.Float.DefaultSpeed,
    PlatformY = 0,
    Active = true,
    Dragging = false,
    DragInput = nil,
    DragStart = nil,
    StartPos = nil
}

local Platform = nil

local PlatformController = {}
PlatformController.__index = PlatformController

function PlatformController.new(services, config, state)
    local self = setmetatable({}, PlatformController)
    self.Services = services
    self.Config = config
    self.State = state
    return self
end

function PlatformController:createPlatform()
    if Platform then return end
    local platform = Instance.new("Part")
    platform.Name = "FloatPlatform"
    platform.Size = self.Config.Float.PlatformSize
    platform.Transparency = self.Config.Float.PlatformTransparency
    platform.BrickColor = BrickColor.new("Really Black")
    platform.Material = Enum.Material.ForceField
    platform.Anchored = true
    platform.CanCollide = true
    platform.Parent = workspace
    Platform = platform
    self.State.PlatformY = 0
end

function PlatformController:destroyPlatform()
    if Platform then
        Platform:Destroy()
        Platform = nil
    end
    self.State.PlatformY = 0
end

function PlatformController:updatePlatform()
    local char = self.Services.Players.LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    local rot = root.CFrame - root.CFrame.Position
    if self.State.PlatformY == 0 then
        self.State.PlatformY = root.Position.Y - self.Config.Float.PlatformOffset
    end
    self.State.PlatformY = self.State.PlatformY + (self.State.Direction * self.State.FloatSpeed)
    if Platform then
        Platform.Position = Vector3.new(root.Position.X, self.State.PlatformY, root.Position.Z)
    end
    root.CFrame = CFrame.new(
        root.Position.X,
        self.State.PlatformY + self.Config.Float.PlatformOffset,
        root.Position.Z
    ) * rot
end

function PlatformController:handleCharacterAdded(character)
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        self:destroyPlatform()
    end)
end

function PlatformController:connectEvents()
    local player = self.Services.Players.LocalPlayer
    self.Connections = {}
    table.insert(self.Connections, player.CharacterAdded:Connect(function(character)
        self:handleCharacterAdded(character)
    end))
    if player.Character then
        self:handleCharacterAdded(player.Character)
    end
    table.insert(self.Connections, self.Services.RunService.RenderStepped:Connect(function()
        if not self.State.Active or not self.State.FloatEnabled then return end
        self:updatePlatform()
    end))
end

function PlatformController:cleanup()
    self:destroyPlatform()
    if self.Connections then
        for _, connection in pairs(self.Connections) do
            if connection and connection.Disconnect then
                connection:Disconnect()
            end
        end
        self.Connections = nil
    end
end

local UIController = {}
UIController.__index = UIController

function UIController.new(services, config, state, platformController)
    local self = setmetatable({}, UIController)
    self.Services = services
    self.Config = config
    self.State = state
    self.PlatformController = platformController
    self.Buttons = {}
    return self
end

function UIController:createScreenGui()
    local sg = Instance.new("ScreenGui")
    sg.Name = self.Config.UI.Name
    sg.DisplayOrder = self.Config.UI.DisplayOrder
    sg.IgnoreGuiInset = true
    sg.ResetOnSpawn = false
    local success = pcall(function()
        sg.Parent = self.Services.CoreGui
    end)
    if not success then
        sg.Parent = self.Services.Players.LocalPlayer.PlayerGui
    end
    return sg
end

function UIController:createMainFrame(parent)
    local main = Instance.new("Frame", parent)
    main.Size = self.Config.UI.Size
    main.Position = self.Config.UI.DefaultPosition
    main.BackgroundTransparency = 0
    main.BackgroundColor3 = self.Config.UI.BackgroundColor
    main.BorderSizePixel = 1
    main.BorderColor3 = self.Config.UI.BorderColor
    main.Active = true
    return main
end

function UIController:createDivider(parent, position, size)
    local divider = Instance.new("Frame", parent)
    divider.Position = position
    divider.Size = size
    divider.BackgroundColor3 = self.Config.UI.DividerColor
    divider.BorderSizePixel = 0
    divider.Active = false
    return divider
end

function UIController:enableDrag(obj, mainFrame)
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            self.State.Dragging = true
            self.State.DragStart = input.Position
            self.State.StartPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    self.State.Dragging = false
                end
            end)
        end
    end)
    obj.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch then
            self.State.DragInput = input
        end
    end)
end

function UIController:createButton(text, position, size, parent)
    local button = Instance.new("TextButton", parent)
    button.Text = text
    button.Position = position
    button.Size = size
    button.BorderSizePixel = 0
    button.BackgroundColor3 = self.Config.UI.BackgroundColor
    button.TextColor3 = self.Config.UI.TextColor
    button.Font = self.Config.UI.Font
    button.TextSize = self.Config.UI.TextSize
    button.AutoButtonColor = false
    table.insert(self.Buttons, button)
    return button
end

function UIController:updateButtonStates()
    for _, button in pairs(self.Buttons) do
        if button.Name == "FloatBtn" then
            button.Text = self.State.FloatEnabled and "Float: ON" or "Float: OFF"
            if self.State.FloatEnabled then
                button.BackgroundColor3 = self.Config.UI.FloatActive
                button.TextColor3 = Color3.fromRGB(0, 0, 0)
            else
                button.BackgroundColor3 = self.Config.UI.BackgroundColor
                button.TextColor3 = self.Config.UI.TextColor
            end
        elseif button.Name == "UpBtn" then
            button.BackgroundColor3 = (self.State.Direction == 1) and
                self.Config.UI.ButtonActive or
                self.Config.UI.BackgroundColor
        elseif button.Name == "DownBtn" then
            button.BackgroundColor3 = (self.State.Direction == -1) and
                self.Config.UI.ButtonActive or
                self.Config.UI.BackgroundColor
        elseif button.Name == "SpeedDisplay" then
            button.Text = string.format("%.1f", self.State.FloatSpeed)
        end
    end
end

function UIController:build()
    self.ScreenGui = self:createScreenGui()
    local main = self:createMainFrame(self.ScreenGui)

    self:enableDrag(main, main)

    self.Services.UserInputService.InputChanged:Connect(function(input)
        if input == self.State.DragInput and self.State.Dragging then
            local delta = input.Position - self.State.DragStart
            main.Position = UDim2.new(
                self.State.StartPos.X.Scale,
                self.State.StartPos.X.Offset + delta.X,
                self.State.StartPos.Y.Scale,
                self.State.StartPos.Y.Offset + delta.Y
            )
        end
    end)

    local closeBtn = self:createButton("X", UDim2.new(0, 0, 0, 0), UDim2.new(0, 32, 0, 25), main)
    self:enableDrag(closeBtn, main)
    closeBtn.MouseButton1Click:Connect(function()
        self:cleanup()
    end)

    self:createDivider(main, UDim2.new(0, 32, 0, 0), UDim2.new(0, 1, 0, 25))

    local floatBtn = self:createButton("FLOAT: OFF", UDim2.new(0, 33, 0, 0), UDim2.new(0, 127, 0, 25), main)
    floatBtn.Name = "FloatBtn"
    self:enableDrag(floatBtn, main)
    floatBtn.MouseButton1Click:Connect(function()
        self.State.FloatEnabled = not self.State.FloatEnabled
        if self.State.FloatEnabled then
            self.PlatformController:createPlatform()
        else
            self.State.Direction = 0
            self.PlatformController:destroyPlatform()
        end
        self:updateButtonStates()
    end)

    self:createDivider(main, UDim2.new(0, 0, 0, 25), UDim2.new(0, 160, 0, 1))

    local upBtn = self:createButton("↑", UDim2.new(0, 0, 0, 26), UDim2.new(0, 32, 0, 25), main)
    upBtn.Name = "UpBtn"
    self:enableDrag(upBtn, main)
    upBtn.MouseButton1Click:Connect(function()
        if not self.State.FloatEnabled then return end
        self.State.Direction = (self.State.Direction == 1) and 0 or 1
        self:updateButtonStates()
    end)

    self:createDivider(main, UDim2.new(0, 32, 0, 26), UDim2.new(0, 1, 0, 25))

    local plusBtn = self:createButton("+", UDim2.new(0, 33, 0, 26), UDim2.new(0, 48, 0, 25), main)
    self:enableDrag(plusBtn, main)
    plusBtn.MouseButton1Click:Connect(function()
        self.State.FloatSpeed = math.min(self.State.FloatSpeed + 0.1, self.Config.Float.MaxSpeed)
        self:updateButtonStates()
    end)

    self:createDivider(main, UDim2.new(0, 81, 0, 26), UDim2.new(0, 1, 0, 25))

    local speedDisplay = self:createButton(
        string.format("%.1f", self.State.FloatSpeed),
        UDim2.new(0, 82, 0, 26),
        UDim2.new(0, 78, 0, 25),
        main
    )
    speedDisplay.Name = "SpeedDisplay"
    self:enableDrag(speedDisplay, main)

    self:createDivider(main, UDim2.new(0, 0, 0, 51), UDim2.new(0, 160, 0, 1))

    local downBtn = self:createButton("↓", UDim2.new(0, 0, 0, 52), UDim2.new(0, 32, 0, 25), main)
    downBtn.Name = "DownBtn"
    self:enableDrag(downBtn, main)
    downBtn.MouseButton1Click:Connect(function()
        if not self.State.FloatEnabled then return end
        self.State.Direction = (self.State.Direction == -1) and 0 or -1
        self:updateButtonStates()
    end)

    self:createDivider(main, UDim2.new(0, 32, 0, 52), UDim2.new(0, 1, 0, 25))

    local minusBtn = self:createButton("-", UDim2.new(0, 33, 0, 52), UDim2.new(0, 48, 0, 25), main)
    self:enableDrag(minusBtn, main)
    minusBtn.MouseButton1Click:Connect(function()
        self.State.FloatSpeed = math.max(self.State.FloatSpeed - 0.1, self.Config.Float.MinSpeed)
        self:updateButtonStates()
    end)

    self:createDivider(main, UDim2.new(0, 81, 0, 52), UDim2.new(0, 1, 0, 25))

    local resetBtn = self:createButton("Reset", UDim2.new(0, 82, 0, 52), UDim2.new(0, 78, 0, 25), main)
    self:enableDrag(resetBtn, main)
    resetBtn.MouseButton1Click:Connect(function()
        self.PlatformController:destroyPlatform()
        self.State.FloatEnabled = false
        self.State.Direction = 0
        self.State.FloatSpeed = self.Config.Float.DefaultSpeed
        self.State.PlatformY = 0
        self:updateButtonStates()
    end)

    self.MainFrame = main
    self:updateButtonStates()

    return self
end

function UIController:cleanup()
    self.State.Active = false
    self.State.FloatEnabled = false
    self.State.Direction = 0
    self.PlatformController:destroyPlatform()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
        self.ScreenGui = nil
    end
end

local MainController = {}
MainController.__index = MainController

function MainController.new()
    local self = setmetatable({}, MainController)
    self.PlatformController = PlatformController.new(Services, Config, State)
    self.UIController = UIController.new(Services, Config, State, self.PlatformController)
    self.UIController:build()
    self.PlatformController:connectEvents()
    return self
end

function MainController:cleanup()
    if self.PlatformController then self.PlatformController:cleanup() end
    if self.UIController then self.UIController:cleanup() end
end

local controller = MainController.new()

return function()
    controller:cleanup()
end
