local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/FabJheiny/Scripts/refs/heads/main/Library%20Teste"))()

local Window = Library:CreateWindow({
    Title = "Prism Hub",
    Subtitle = "Premium"
})

local Main = Window:CreateTab("Main")
local Combat = Window:CreateTab("Combat")
local Player = Window:CreateTab("Player")
local Visual = Window:CreateTab("Visual")
local Settings = Window:CreateTab("Settings")

Main:CreateToggle({
    Name = "Auto Farm",
    Description = "Collects resources automatically while you are playing.",
    Default = true,
    Callback = function(v)
        print("Auto Farm:", v)
    end
})

Main:CreateToggle({
    Name = "Auto Collect",
    Description = "Automatically grabs nearby drops and rewards.",
    Default = false,
    Callback = function(v)
        print("Auto Collect:", v)
    end
})

Main:CreateSlider({
    Name = "Walk Speed",
    Min = 16,
    Max = 100,
    Default = 72,
    Callback = function(v)
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
    end
})

Main:CreateButton({
    Name = "✦ Teleport to Spawn",
    Callback = function()
        local hrp = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(0,10,0)
        end
    end
})

Main:CreateDropdown({
    Name = "Game Mode",
    Options = {"Classic","Hardcore","Arena","Sandbox"},
    Default = "Classic",
    Callback = function(v)
        print("Selected:", v)
    end
})

Main:CreateTextbox({
    Name = "Player Name",
    Placeholder = "Enter username...",
    Callback = function(v)
        print("Textbox:", v)
    end
})

Main:CreateLabel("v2.4.1 · Delta Android · No deps")

Main:CreateParagraph({
    Title = "About",
    Content = "Single-file library with zero dependencies. Mobile-first drag and touch support with futuristic prism visuals."
})

Combat:CreateToggle({
    Name = "Kill Aura",
    Description = "Automatically attacks nearby enemies.",
    Default = false,
    Callback = function(v)
        print("Kill Aura:", v)
    end
})

Combat:CreateSlider({
    Name = "Attack Range",
    Min = 5,
    Max = 50,
    Default = 15,
    Callback = function(v)
        print("Range:", v)
    end
})

Player:CreateSlider({
    Name = "Jump Power",
    Min = 50,
    Max = 200,
    Default = 100,
    Callback = function(v)
        game.Players.LocalPlayer.Character.Humanoid.JumpPower = v
    end
})

Player:CreateButton({
    Name = "Reset Character",
    Callback = function()
        game.Players.LocalPlayer.Character:BreakJoints()
    end
})

Visual:CreateToggle({
    Name = "Fullbright",
    Description = "Improves map visibility.",
    Default = false,
    Callback = function(v)
        print("Fullbright:", v)
    end
})

Settings:CreateButton({
    Name = "Rejoin Server",
    Callback = function()
        game:GetService("TeleportService"):Teleport(game.PlaceId)
    end
})
